---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const all = await getCollection('projects');
  const sorted = all.sort((a, b) => a.data.order - b.data.order);
  return sorted.map((entry, idx) => ({
    params: { slug: entry.slug },
    props: {
      entry,
      prev: idx > 0 ? sorted[idx - 1] : null,
      next: idx < sorted.length - 1 ? sorted[idx + 1] : null
    }
  }));
}

interface Props {
  entry: CollectionEntry<'projects'>;
  prev: CollectionEntry<'projects'> | null;
  next: CollectionEntry<'projects'> | null;
}

const { entry, prev, next } = Astro.props;
const { Content } = await entry.render();
const data = entry.data;
---
<BaseLayout
  title={`${data.title} - Sagar Ahuja`}
  description={data.summary}
>
  <article class="article">
    <div class="container-narrow">
      <header>
        <a href="/work" class="crumb">&larr; All work</a>
        <h1>{data.title}</h1>
        <p class="deck">{data.summary}</p>
        <div class="meta-row">
          <span><strong>{data.company}</strong></span>
          {data.role && <span>{data.role}</span>}
          <span>{data.year}</span>
          {data.timeframe && <span>{data.timeframe}</span>}
        </div>
      </header>

      {data.metrics && data.metrics.length > 0 && (
        <div class="metric-strip" id="metric-strip">
          {data.metrics.map(m => {
            const pctMatch = m.value.match(/(\d+(?:\.\d+)?)%/);
            const pct = pctMatch ? Math.min(100, parseFloat(pctMatch[1])) : null;
            return (
              <div class="cell">
                <span class="value">{m.value}</span>
                <span class="label">{m.label}</span>
                {pct !== null && (
                  <div class="bar"><div class="bar-fill" style={`--bar-w: ${pct}%`}></div></div>
                )}
              </div>
            );
          })}
        </div>
      )}

      <script is:inline>
        (function() {
          const strip = document.getElementById('metric-strip');
          if (!strip) return;
          if ('IntersectionObserver' in window) {
            const io = new IntersectionObserver((entries) => {
              entries.forEach(e => {
                if (e.isIntersecting) {
                  strip.classList.add('visible');
                  io.disconnect();
                }
              });
            }, { threshold: 0.3 });
            io.observe(strip);
          } else {
            strip.classList.add('visible');
          }
        })();
      </script>

      <div class="body">
        <Content />
      </div>

      {data.screenshots && data.screenshots.length > 0 && (
        <section class="screenshots">
          <h2>Screens</h2>
          <div class={`screenshot-grid count-${data.screenshots.length}`}>
            {data.screenshots.map((s) => (
              <figure class="screenshot">
                <a href={s.src} target="_blank" rel="noopener" aria-label={s.alt ?? s.caption ?? 'View screenshot'}>
                  <img src={s.src} alt={s.alt ?? s.caption ?? ''} loading="lazy" />
                </a>
                {s.caption && <figcaption>{s.caption}</figcaption>}
              </figure>
            ))}
          </div>
        </section>
      )}

      <div class="nav-footer">
        {prev ? (
          <a href={`/projects/${prev.slug}`}>&larr; {prev.data.title}</a>
        ) : <span></span>}
        {next ? (
          <a href={`/projects/${next.slug}`}>{next.data.title} &rarr;</a>
        ) : <span></span>}
      </div>
    </div>
  </article>
</BaseLayout>
