---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import StatsStrip from '../components/StatsStrip.astro';
import PageNav from '../components/PageNav.astro';
import SideProjectCard from '../components/SideProjectCard.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const featured = allProjects
  .filter(p => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);

const sideProjects = await getCollection('side-projects');
const sortedSide = sideProjects.sort((a, b) => a.data.order - b.data.order);

const principles = [
  {
    text: 'Earlier we built for the forest - grouping users into cohorts. Now we build for every tree - every individual user.',
    slug: 'app-redesign-cohort-lobby',
    project: 'App Redesign'
  },
  {
    text: 'Launch is the starting line, not the finish line.',
    slug: 'loyalty-revamp-skillz',
    project: 'Loyalty Program Revamp'
  },
  {
    text: 'When data is the blocker, find the cheap experiment that creates it.',
    slug: 'challenges-tooltips',
    project: 'Challenges Adoption'
  },
  {
    text: 'Anchor every cross-functional debate to the goal everyone already shares.',
    slug: 'platform-roadmap-separation',
    project: 'Platform Roadmap Separation'
  }
];

const experiencePreview = [
  {
    when: 'Mar 2025 - Feb 2026',
    title: 'Senior Product Manager',
    where: 'Skillz',
    blurb: 'Led Engagement, Monetization, and LiveOps. Owned the full user lifecycle and shipped loyalty, lifecycle, and agentic AI tooling across the platform.'
  },
  {
    when: 'Jun 2019 - Feb 2025',
    title: 'Senior Product Manager',
    where: 'Games24x7',
    blurb: 'Led platform and growth product strategy for B2C apps with 10M+ users. Built the cohort-configurable app architecture, experimentation engine, and analytics platform used company-wide.'
  },
  {
    when: 'Jun 2016 - Apr 2018',
    title: 'Fellow and Fellow Advisor',
    where: 'Teach For India',
    blurb: 'Owned program strategy for 1,000+ students and 25+ Fellows. Designed Tarabati, a digital learning program with 65% uplift in student learning outcomes.'
  },
  {
    when: 'Jun 2013 - May 2016',
    title: 'Business Development Manager',
    where: 'Tech Mahindra',
    blurb: 'Led West Africa market entry for BFSI. Drove $100K annual revenue in a new market and improved enterprise reporting data quality from 5% to 95%.'
  }
];
---
<BaseLayout
  title="Sagar Ahuja - Senior Product Manager"
  description="Senior Product Manager. 11 years experience, 7 in PM. Gaming, growth, engagement, monetization, AI-enabled product workflows."
>
  <PageNav />

  <section class="hero" data-has-bg="true" data-section="home_hero">
    <div class="container">
      <div class="role-chips" aria-label="Roles I am open to">
        <span class="role-chip is-status"><span class="role-dot" aria-hidden="true"></span>Available now</span>
        <span class="role-chip">AI PM</span>
        <span class="role-chip">Senior PM</span>
        <span class="role-chip">Lead PM</span>
        <span class="role-chip">Group PM</span>
      </div>
      <h1>
        I'm the PM who leads with “<span class="gradient-text">Here it is</span>.” Not “Picture this.”
      </h1>
      <p class="builder-line">
        Builder at heart. Currently shipping AI-native systems across personalization, lifecycle, and growth.
      </p>
      <div class="ctas">
        <a href="#contact" class="btn btn-primary">Get in touch <span class="arrow">→</span></a>
        <a href="#work" class="btn btn-secondary">See case studies</a>
      </div>

      <StatsStrip />
    </div>
  </section>

  {/* Featured: a small picked-highlights section between the hero and the
       Selected work grid. Two items only, alternating image side, no card
       backgrounds - intentionally distinct from the card-grid sections. */}
  <section class="featured-section" id="featured" data-section="home_featured" aria-label="Featured">
    <div class="container">
      <header class="featured-head reveal">
        <span class="featured-tag">Featured</span>
      </header>

      <article class="feature feature-firstclub reveal">
        <a href="/firstclub" class="feature-link" aria-label="View the FirstClub pitch page">
          <div class="feature-visual">
            <img src="/firstclub/firstclub-specials.jpg" alt="Today's Specials section from the FirstClub pitch: Limited Edition, Member's Pick, Season's Best" loading="lazy" />
            <span class="feature-badge"><span class="feature-dot" aria-hidden="true"></span>Currently shipping</span>
          </div>
          <div class="feature-text">
            <span class="feature-eyebrow">Pitch site · 2026</span>
            <h3 class="feature-headline">FirstClub: a pitch page for a $55M Series B quick commerce</h3>
            <p class="feature-body">
              A one-page pitch built for a single company. Contains a 12-month outsider's thesis on the four problems FirstClub needs to solve to scale from 170K to 1M households.
            </p>
            <span class="feature-cta">View the pitch <span class="arrow">→</span></span>
          </div>
        </a>
      </article>

      <article class="feature feature-mygate reveal">
        <a href="/mygate/" class="feature-link" aria-label="View the MyGate Homes prototype">
          <div class="feature-visual">
            <img src="/mygate/mygate-verified-owners.jpg" alt="MyGate Homes prototype: Verified owners only card, Sell or rent out your home button, and Pre-verified address / No broker spam / Zero brokerage chips" loading="lazy" />
            <span class="feature-badge"><span class="feature-dot" aria-hidden="true"></span>Currently shipping</span>
          </div>
          <div class="feature-text">
            <span class="feature-eyebrow">Prototype · 2026</span>
            <h3 class="feature-headline">MyGate Homes: a real-estate prototype for 5.7M verified residents</h3>
            <p class="feature-body">
              A clickable React prototype of MyGate Homes plus a 12-month roadmap. Built on MyGate's real moat: verified residents, verified addresses, and gate-issued visit passes. Verified owners only, zero brokerage.
            </p>
            <span class="feature-cta">View the prototype <span class="arrow">→</span></span>
          </div>
        </a>
      </article>

      <article class="feature feature-app-redesign reveal">
        <a href="/projects/app-redesign-cohort-lobby" class="feature-link" aria-label="Read the App Redesign case study">
          <div class="feature-visual">
            <img src="/case-studies/app-redesign-cohort-illustration.jpg" alt="Three users with phones showing different personalised home screens: Travel, Music, and Home themes" loading="lazy" />
          </div>
          <div class="feature-text">
            <span class="feature-eyebrow">Case study · Games24x7 · 2023</span>
            <h3 class="feature-headline">The app redesign that moved 17M users to a per-cohort lobby</h3>
            <p class="feature-body">
              Rebuilt the app architecture so it could be configured differently for each user cohort in real time, with parallel A/B tests running without app releases.
            </p>
            <ul class="feature-metrics">
              <li><strong>+9%</strong><span>new user retention</span></li>
              <li><strong>+3%</strong><span>ARPU on existing</span></li>
              <li><strong>-82%</strong><span>release dependency</span></li>
            </ul>
            <span class="feature-cta">Read the case study <span class="arrow">→</span></span>
          </div>
        </a>
      </article>
    </div>
  </section>

  <section class="section" id="work" data-section="home_work">
    <div class="container">
      <div class="section-title">
        <div>
          <div class="eyebrow">Selected work</div>
          <h2><a href="/work" class="h2-link">Case studies <span class="arrow">→</span></a></h2>
        </div>
        <a href="/work" class="link">See all 17 projects →</a>
      </div>
      <div class="project-grid reveal-stagger">
        {featured.map(p => (
          <ProjectCard
            href={`/projects/${p.slug}`}
            title={p.data.title}
            company={p.data.company}
            year={p.data.year}
            summary={p.data.summary}
            tags={p.data.tags}
            metrics={p.data.metrics}
            icon={p.data.icon}
            quote={p.data.quote}
            status={p.data.status}
            image={p.data.image}
            featured={true}
          />
        ))}
      </div>
    </div>
  </section>

  <hr class="section-divider" />

  <section class="section" id="side-projects" data-section="home_side_projects">
    <div class="container">
      <div class="section-title">
        <div>
          <div class="eyebrow">Builds, not just plans</div>
          <h2><a href="/side-projects" class="h2-link">Building outside work <span class="arrow">→</span></a></h2>
        </div>
        <a href="/side-projects" class="link">See all →</a>
      </div>
      <div class="side-grid reveal-stagger">
        {sortedSide.map(sp => (
          <SideProjectCard
            slug={sp.slug}
            title={sp.data.title}
            type={sp.data.type}
            year={sp.data.year}
            summary={sp.data.summary}
            tags={sp.data.tags}
            link={sp.data.link}
            linkLabel={sp.data.linkLabel}
            mainHref={sp.data.mainHref}
            icon={sp.data.icon}
            status={sp.data.status}
            image={sp.data.image}
          />
        ))}
      </div>
    </div>
  </section>

  <hr class="section-divider" />

  <section class="section" id="about" data-section="home_about">
    <div class="container">
      <div class="section-title">
        <div>
          <h2>Who am I?</h2>
        </div>
      </div>
      <div class="about-wrap">
        <div class="about-text reveal">
          <div class="about-photo">
            <img src="/sagar.jpg" alt="Sagar Ahuja portrait" width="400" height="600" />
          </div>
          <p>
            I am a <strong>product builder</strong> with 11 years of experience, 7 in product, shipping the systems that turn user understanding into growth - increasingly built on AI.
          </p>
          <p>
            The shape of my career has been one long bet that <strong>user behaviour is the most interesting object in product</strong>. Teach For India taught me to read it without telling. Tech Mahindra taught me to operate in someone else's language. Games24x7 and Skillz taught me to instrument it at scale. <strong>AI is what makes the loop fast enough to be useful.</strong>
          </p>
          <p>
            My current obsession is <strong>AI as a unit-economics lever</strong>, not as a product surface. The interesting bet is what an agentic workflow changes about who can ship, how fast, and at what cost. Most of the work I want to do next sits on <strong>that thread</strong>.
          </p>
          <div class="roots-chips" aria-label="Pursuits outside product">
            <span class="root-chip">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M8 2h8l-1 4h-6l-1-4z"/><path d="M6 6h12l-2 8H8l-2-8z"/><path d="M9 14v4h6v-4"/><path d="M7 22h10"/></svg>
              Chess: state champion · 4x national
            </span>
            <span class="root-chip">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2v6"/><circle cx="12" cy="11" r="3"/><path d="M5 20l4-6 3 2 3-2 4 6"/></svg>
              Karate: brown IV belt
            </span>
            <span class="root-chip">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15 15 0 0 1 0 20"/><path d="M12 2a15 15 0 0 0 0 20"/></svg>
              15+ countries · 5 continents
            </span>
          </div>
        </div>

        <div class="about-panels reveal-stagger">
          <div class="panel">
            <h4>Domain strengths</h4>
            <ul>
              <li><strong>AI-Enabled Product Systems</strong></li>
              <li>Personalization and ML</li>
              <li>Experimentation Platforms</li>
              <li>Engagement and Lifecycle</li>
              <li>Loyalty and Retention</li>
              <li>Monetization</li>
            </ul>
          </div>
          <div class="panel">
            <h4>Industries</h4>
            <ul>
              <li>Gaming (India and US)</li>
              <li>EdTech</li>
              <li>BFSI (West Africa)</li>
            </ul>
          </div>
          <div class="panel">
            <h4>Education</h4>
            <ul>
              <li><strong>ISB</strong> MBA, 2018-2019</li>
              <li><strong>Stanford</strong> Product Management Certificate, 2023</li>
              <li><strong>UPES</strong> B.Tech, 2009-2013</li>
            </ul>
          </div>
          <div class="panel">
            <h4>Currently exploring</h4>
            <ul>
              <li>Agentic AI in operational workflows</li>
              <li>AI-native lifecycle and personalization</li>
              <li>LLMs as a unit-economics lever</li>
              <li>Behavioral economics in product design</li>
            </ul>
          </div>
        </div>

      </div>
    </div>
  </section>

  <hr class="section-divider" />

  <section class="section" id="principles" data-section="home_principles">
    <div class="container">
      <div class="section-title">
        <div>
          <div class="eyebrow">How I think</div>
          <h2>Principles I work by</h2>
        </div>
      </div>
      <div class="principles-grid reveal-stagger">
        {principles.map((p, i) => (
          <a href={`/projects/${p.slug}`} class="principle-card">
            <span class="pnum">PRINCIPLE {String(i + 1).padStart(2, '0')}</span>
            <p class="ptext">{p.text}</p>
            <div class="pmeta">
              <span>From {p.project}</span>
              <span class="arrow">→</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <hr class="section-divider" />

  <section class="section" id="experience" data-section="home_experience">
    <div class="container">
      <div class="section-title">
        <div>
          <div class="eyebrow">Career</div>
          <h2><a href="/resume" class="h2-link">Experience <span class="arrow">→</span></a></h2>
        </div>
        <a href="/resume" class="link">Full resume →</a>
      </div>
      <div class="experience-preview reveal-stagger">
        {experiencePreview.map(e => (
          <div class="exp-card">
            <div class="when">{e.when}</div>
            <h3>{e.title}</h3>
            <div class="where">{e.where}</div>
            <p>{e.blurb}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <hr class="section-divider" />

  <section class="section" id="contact" data-section="home_contact">
    <div class="container">
      <div class="section-title">
        <div>
          <div class="eyebrow">Get in touch</div>
          <h2>Want to talk?</h2>
        </div>
      </div>
      <div class="contact-block">
        <a href="mailto:sagarahuja@gmail.com" class="contact-card">
          <span class="label">Email</span>
          <span class="value">sagarahuja@gmail.com</span>
        </a>
        <a href="https://linkedin.com/in/sagar-ahuja-/" target="_blank" rel="noopener" class="contact-card">
          <span class="label">LinkedIn</span>
          <span class="value">linkedin.com/in/sagar-ahuja-</span>
        </a>
        <a href="/Sagar%20Ahuja%20Resume.pdf" download="Sagar Ahuja Resume.pdf" class="contact-card">
          <span class="label">Resume</span>
          <span class="value">Download PDF ↓</span>
        </a>
      </div>
    </div>
  </section>

  <style>
    /* ============== Hero role chips ============== */
    .role-chips {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
      margin-bottom: 1.25rem;
    }
    .role-chip {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      font-family: var(--font-mono);
      font-size: 0.72rem;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--text-muted);
      padding: 0.28rem 0.62rem;
      border: 1px solid var(--border);
      border-radius: 999px;
      background: var(--bg-card);
    }
    .role-chip.is-status {
      color: var(--accent);
      background: var(--accent-soft);
      border-color: var(--accent-line);
    }
    .role-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: #22c55e;
      box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.5);
      animation: rolePulse 2s ease-in-out infinite;
    }
    @keyframes rolePulse {
      0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.55); }
      50%      { opacity: 0.6; box-shadow: 0 0 0 5px rgba(34, 197, 94, 0); }
    }
    @media (prefers-reduced-motion: reduce) {
      .role-dot { animation: none; }
    }

    /* ============== About: roots chips ============== */
    .roots-chips {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
      margin-top: 1rem;
      padding-top: 1rem;
      border-top: 1px dashed var(--border);
    }
    .root-chip {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      font-family: var(--font-mono);
      font-size: 0.72rem;
      color: var(--text-muted);
      padding: 0.28rem 0.62rem;
      border: 1px solid var(--border);
      border-radius: 999px;
      background: var(--bg-card);
    }
    .root-chip svg { width: 12px; height: 12px; flex-shrink: 0; opacity: 0.85; }

    /* ============== Featured section ==============
       Distinct from the card-grid sections that follow:
       - Centered heading, gentler kerning, accent tag above
       - No card background; only hairline rules separate items
       - Bigger headline typography (clamps up to 1.9rem)
       - Alternating image side per item on desktop
       - Each image gets its own treatment so the page does not read
         as a wall of identical card thumbnails. */

    .featured-section {
      padding: 1.25rem 0 0.75rem;
      position: relative;
    }
    @media (min-width: 768px) { .featured-section { padding: 1.5rem 0 1rem; } }

    .featured-head {
      text-align: center;
      margin-bottom: 1rem;
    }
    @media (min-width: 768px) { .featured-head { margin-bottom: 1.25rem; } }

    .featured-tag {
      display: inline-block;
      font-family: var(--font-mono);
      font-size: 0.72rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--accent);
      padding: 0.25rem 0.7rem;
      border: 1px solid var(--accent-line);
      border-radius: 999px;
      background: var(--accent-soft);
    }

    /* ============== Feature item ============== */
    .feature {
      padding: 1.25rem 0;
      border-top: 1px solid var(--border);
    }
    .feature:last-of-type {
      border-bottom: 1px solid var(--border);
    }
    @media (min-width: 768px) { .feature { padding: 1.5rem 0; } }

    .feature-link {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.25rem;
      text-decoration: none;
      color: inherit;
      transition: opacity 0.22s var(--ease);
    }
    .feature-link:hover { opacity: 0.96; }

    @media (min-width: 768px) {
      .feature-link {
        grid-template-columns: 4fr 8fr;
        gap: 2rem;
        align-items: center;
      }
      /* Alternate the image side on every even-numbered feature so the
         page reads as zigzag rows instead of identical bands. Generalised
         from a hard-coded .feature-app-redesign override so a fourth or
         fifth feature inherits the rhythm without further CSS. */
      .feature:nth-of-type(even) .feature-link { grid-template-columns: 8fr 4fr; }
      .feature:nth-of-type(even) .feature-visual { order: 2; }
      .feature:nth-of-type(even) .feature-text   { order: 1; }
    }

    /* Unified visual treatment so both features look equal in weight:
       same aspect (3:2), same object-fit (cover), same rounded frame.
       What still feels non-card-like vs the sections below: no card
       background on the row itself, just hairline dividers and bigger
       typography; alternating image side per item; an overlay badge
       on the first feature; and a metrics row on the second. */
    .feature-visual {
      position: relative;
      border-radius: 12px;
      overflow: hidden;
      background: var(--bg-subtle);
      aspect-ratio: 16 / 9;
    }
    .feature-visual img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    /* 'Currently shipping' pulse pill, only on the FirstClub feature.
       Sits as a small overlay in the top-left of the image, with a soft
       dark glass background so it stays readable on any image content. */
    .feature-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      position: absolute;
      top: 0.7rem;
      left: 0.7rem;
      padding: 0.32rem 0.7rem;
      border-radius: 999px;
      background: rgba(15, 18, 26, 0.62);
      backdrop-filter: blur(6px);
      -webkit-backdrop-filter: blur(6px);
      font-family: var(--font-mono);
      font-size: 0.7rem;
      color: #fff;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      z-index: 2;
    }
    .feature-dot {
      width: 7px; height: 7px; border-radius: 50%;
      background: #5eead4;
      box-shadow: 0 0 0 0 rgba(94, 234, 212, 0.6);
      animation: featurePulse 2s ease-in-out infinite;
    }
    @keyframes featurePulse {
      0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(94, 234, 212, 0.6); }
      50%      { opacity: 0.55; box-shadow: 0 0 0 6px rgba(94, 234, 212, 0); }
    }
    @media (prefers-reduced-motion: reduce) {
      .feature-dot { animation: none; box-shadow: none; }
    }

    .feature-eyebrow {
      display: inline-block;
      font-family: var(--font-mono);
      font-size: 0.74rem;
      color: var(--text-dim);
      letter-spacing: 0.12em;
      text-transform: uppercase;
      margin-bottom: 0.6rem;
    }
    .feature-headline {
      font-size: clamp(1.2rem, 2.6vw, 1.5rem);
      font-weight: 700;
      letter-spacing: -0.018em;
      line-height: 1.2;
      margin: 0 0 0.6rem;
      color: var(--text);
    }
    .feature-body {
      font-size: 0.95rem;
      line-height: 1.55;
      color: var(--text-muted);
      margin: 0 0 0.85rem;
    }
    @media (min-width: 768px) { .feature-body { font-size: 1rem; } }

    .feature-metrics {
      list-style: none;
      padding: 0;
      margin: 0 0 0.85rem;
      display: flex;
      gap: 1.25rem;
      flex-wrap: wrap;
    }
    .feature-metrics li {
      display: flex;
      flex-direction: column;
      line-height: 1.1;
    }
    .feature-metrics strong {
      font-size: 1.15rem;
      font-weight: 700;
      color: var(--accent);
      letter-spacing: -0.015em;
      margin-bottom: 0.2rem;
    }
    .feature-metrics span {
      font-family: var(--font-mono);
      font-size: 0.72rem;
      color: var(--text-dim);
      letter-spacing: 0.05em;
      text-transform: uppercase;
    }

    .feature-cta {
      color: var(--accent);
      font-size: 0.95rem;
      font-weight: 600;
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      transition: gap 0.22s var(--ease);
    }
    .feature-link:hover .feature-cta { gap: 0.7rem; }
  </style>
</BaseLayout>
