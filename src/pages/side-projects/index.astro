---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SideProjectCard from '../../components/SideProjectCard.astro';
import { getCollection } from 'astro:content';

const sideProjects = await getCollection('side-projects');
const sorted = sideProjects.sort((a, b) => a.data.order - b.data.order);
---
<BaseLayout title="Building outside work - Sagar Ahuja">
  <section class="section">
    <div class="container">
      <div class="eyebrow">Builds, not just plans</div>
      <h1 style="margin-bottom:1rem;">Building outside work</h1>
      <p style="font-size:1.1rem;color:var(--text-muted);max-width:680px;margin-bottom:3rem;">
        Projects I built outside of formal work. Included because they demonstrate product thinking, ownership, and willingness to ship.
      </p>
      <div class="side-grid">
        {sorted.map(sp => (
          <SideProjectCard
            slug={sp.slug}
            title={sp.data.title}
            type={sp.data.type}
            year={sp.data.year}
            summary={sp.data.summary}
            tags={sp.data.tags}
            link={sp.data.link}
            linkLabel={sp.data.linkLabel}
            icon={sp.data.icon}
            status={sp.data.status}
            image={sp.data.image}
          />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
