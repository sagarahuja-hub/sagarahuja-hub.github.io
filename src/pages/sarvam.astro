  <script slot="head" is:inline>
    document.addEventListener('DOMContentLoaded', function() {
      // ----- Reveal on scroll -----
      if ('IntersectionObserver' in window) {
        var io = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting) { entry.target.classList.add('visible'); io.unobserve(entry.target); }
          });
        }, { threshold: 0.12 });
        document.querySelectorAll('.reveal, .reveal-stagger').forEach(function(el) { io.observe(el); });
      } else {
        document.querySelectorAll('.reveal, .reveal-stagger').forEach(function(el) { el.classList.add('visible'); });
      }

      // ----- Language data -----
      // English + Hindi are live (verified). Other languages show a "coming soon"
      // state using verified greeting words only - real translations ship later.
      var LANGS = [
        { code: 'en', name: 'English', bcp: 'en-IN', status: 'live',
          text: 'Sarvam has won the model race. The real prize is adoption: turning world-class models into products that a billion Indians use every day.' },
        { code: 'hi', name: 'हिन्दी', bcp: 'hi-IN', status: 'live',
          text: 'सर्वम ने मॉडल की दौड़ जीत ली है। असली इनाम है अपनाना: विश्वस्तरीय मॉडलों को ऐसे प्रोडक्ट में बदलना जिन्हें एक अरब भारतीय रोज़ इस्तेमाल करें।' },
        { code: 'mr', name: 'मराठी', bcp: 'mr-IN', status: 'soon', greet: 'नमस्कार' },
        { code: 'bn', name: 'বাংলা', bcp: 'bn-IN', status: 'soon', greet: 'নমস্কার' },
        { code: 'ta', name: 'தமிழ்', bcp: 'ta-IN', status: 'soon', greet: 'வணக்கம்' },
        { code: 'te', name: 'తెలుగు', bcp: 'te-IN', status: 'soon', greet: 'నమస్తే' },
        { code: 'kn', name: 'ಕನ್ನಡ', bcp: 'kn-IN', status: 'soon', greet: 'ನಮಸ್ಕಾರ' }
      ];

      var byCode = {};
      LANGS.forEach(function(l) { byCode[l.code] = l; });

      var sel = document.getElementById('lang-select');
      var ttsText = document.getElementById('tts-text');
      var ttsWords = document.getElementById('tts-words');
      var ttsChars = document.getElementById('tts-chars');
      var sttText = document.getElementById('stt-text');
      var sttLang = document.getElementById('stt-lang');
      var dubGrid = document.getElementById('dub-grid');

      if (sel) {
        LANGS.forEach(function(l) {
          var o = document.createElement('option');
          o.value = l.code; o.textContent = l.name;
          sel.appendChild(o);
        });
      }

      if (dubGrid) {
        LANGS.forEach(function(l) {
          var chip = document.createElement('div');
          chip.className = 'dub-chip' + (l.code === 'en' ? ' active' : '');
          chip.setAttribute('data-code', l.code);
          chip.setAttribute('role', 'button');
          chip.innerHTML = '<span class="pp"><svg viewBox="0 0 24 24" fill="currentColor"><polygon points="6 4 20 12 6 20 6 4"/></svg></span>'
            + '<span class="dub-wave" aria-hidden="true"><span></span><span></span><span></span><span></span></span>'
            + '<span class="ln">' + l.name + '</span>'
            + (l.status !== 'live' ? '<span class="dub-soon">soon</span>' : '');
          dubGrid.appendChild(chip);
        });
      }

      function countWords(s) { return (s.trim().match(/\S+/g) || []).length; }

      // refs + state
      var play = document.getElementById('tts-play');
      var mic = document.getElementById('stt-mic');
      var micLabel = document.getElementById('stt-mic-label');
      var sttWave = document.getElementById('stt-wave');
      var curLang = byCode['en'];

      function stopSpeech() {
        if (window.speechSynthesis) { try { window.speechSynthesis.cancel(); } catch (e) {} }
        if (play) { play.classList.remove('playing'); play.setAttribute('aria-label', 'Play'); }
        document.querySelectorAll('.voice-card.speaking').forEach(function(c) { c.classList.remove('speaking'); });
        if (dubGrid) dubGrid.querySelectorAll('.dub-chip.playing').forEach(function(c) { c.classList.remove('playing'); });
        var ds = document.getElementById('dub-status');
        if (ds && ds.getAttribute('data-idle')) ds.textContent = ds.getAttribute('data-idle');
      }
      function speakText(text, bcp, onEnd) {
        if (!('speechSynthesis' in window) || !text) return false;
        var u = new SpeechSynthesisUtterance(text);
        u.lang = bcp;
        var v = pickVoice(bcp); if (v) u.voice = v;
        u.rate = 0.98;
        u.onend = function() { onEnd && onEnd(); };
        u.onerror = function() { onEnd && onEnd(); };
        window.speechSynthesis.cancel();
        window.speechSynthesis.speak(u);
        return true;
      }

      function render(code) {
        var l = byCode[code] || LANGS[0];
        curLang = l;
        stopSpeech();
        if (l.status === 'live') {
          if (ttsText) ttsText.textContent = l.text;
          if (sttText) sttText.textContent = l.text;
          if (ttsWords) ttsWords.textContent = countWords(l.text);
          if (ttsChars) ttsChars.textContent = l.text.length + '/2000';
          if (play) play.classList.remove('disabled');
        } else {
          var ph = '<span class="tts-soon"><span class="greet">' + l.greet + '</span>'
            + '<span class="soon-badge">Coming soon</span>'
            + '<span class="soon-sub"><b>' + l.name + '</b> voice is releasing soon. English and हिन्दी are live now - try them.</span></span>';
          if (ttsText) ttsText.innerHTML = ph;
          if (sttText) sttText.innerHTML = ph;
          if (ttsWords) ttsWords.textContent = '0';
          if (ttsChars) ttsChars.textContent = '0/2000';
          if (play) play.classList.add('disabled');
        }
        if (sttLang) sttLang.textContent = l.name;
        if (dubGrid) {
          dubGrid.querySelectorAll('.dub-chip').forEach(function(c) {
            c.classList.toggle('active', c.getAttribute('data-code') === code);
          });
        }
      }

      render('en');

      if (sel) {
        sel.addEventListener('change', function() {
          render(sel.value);
          if (window.posthog && typeof window.posthog.capture === 'function') {
            window.posthog.capture('playground_lang_switched', { lang: sel.value });
          }
        });
      }

      // ----- Tab switching -----
      var tabs = document.querySelectorAll('.sv-tab');
      var panels = document.querySelectorAll('.sv-panel');
      tabs.forEach(function(tab) {
        tab.addEventListener('click', function() {
          var name = tab.getAttribute('data-tab');
          tabs.forEach(function(t) { t.classList.remove('active'); });
          tab.classList.add('active');
          panels.forEach(function(p) { p.classList.toggle('active', p.getAttribute('data-panel') === name); });
          stopSpeech();
          if (window.posthog && typeof window.posthog.capture === 'function') {
            window.posthog.capture('playground_tab_opened', { tab: name });
          }
        });
      });

      // ----- Text to Speech (real, via Web Speech API) -----
      function pickVoice(bcp) {
        if (!window.speechSynthesis) return null;
        var vs = window.speechSynthesis.getVoices() || [];
        var exact = vs.filter(function(v){ return v.lang === bcp; })[0];
        if (exact) return exact;
        var base = bcp.split('-')[0];
        return vs.filter(function(v){ return v.lang && v.lang.indexOf(base) === 0; })[0] || null;
      }
      if (play) {
        play.addEventListener('click', function() {
          if (play.classList.contains('disabled')) return;
          var was = play.classList.contains('playing');
          stopSpeech();
          if (was) return;
          if (speakText(curLang.text, curLang.bcp, function() { play.classList.remove('playing'); play.setAttribute('aria-label', 'Play'); })) {
            play.classList.add('playing'); play.setAttribute('aria-label', 'Pause');
          } else {
            play.classList.add('playing'); // graceful fallback (animation only)
          }
        });
      }

      // ----- Voice cards: click to hear the script spoken aloud -----
      document.querySelectorAll('.voice-card').forEach(function(card) {
        card.addEventListener('click', function() {
          if (curLang.status !== 'live' || !curLang.text) return;
          var was = card.classList.contains('speaking');
          stopSpeech();
          if (was) return;
          if (speakText(curLang.text, curLang.bcp, function() { card.classList.remove('speaking'); })) {
            card.classList.add('speaking');
          }
        });
      });

      // ----- Speech to Text (real, via Web Speech API) -----
      var SR = window.SpeechRecognition || window.webkitSpeechRecognition;
      var recog = null, listening = false;
      if (mic) {
        if (!SR) {
          mic.classList.add('disabled');
          if (micLabel) micLabel.textContent = 'Live mic not supported here';
        } else {
          mic.addEventListener('click', function() {
            if (listening) { try { recog.stop(); } catch (e) {} return; }
            recog = new SR();
            recog.lang = (curLang.status === 'live') ? curLang.bcp : 'en-IN';
            recog.interimResults = true;
            recog.continuous = false;
            recog.onstart = function() {
              listening = true;
              mic.classList.add('listening');
              if (micLabel) micLabel.textContent = 'Listening... tap to stop';
              if (sttWave) sttWave.classList.add('on');
              if (sttText) sttText.textContent = '';
            };
            recog.onresult = function(e) {
              var t = '';
              for (var i = 0; i < e.results.length; i++) { t += e.results[i][0].transcript; }
              if (sttText) sttText.textContent = t;
            };
            recog.onerror = function(e) {
              if (micLabel) micLabel.textContent = (e.error === 'not-allowed' || e.error === 'service-not-allowed') ? 'Allow mic access to try' : 'Did not catch that - try again';
            };
            recog.onend = function() {
              listening = false;
              mic.classList.remove('listening');
              if (sttWave) sttWave.classList.remove('on');
              if (micLabel) micLabel.textContent = 'Tap and speak';
              if (sttText && !sttText.textContent.trim() && curLang.status === 'live') sttText.textContent = curLang.text;
            };
            try { recog.start(); } catch (err) {}
          });
        }
      }

      // ----- Dubbing: click a language to hear the pitch dubbed aloud -----
      var dubStatus = document.getElementById('dub-status');
      if (dubGrid) {
        dubGrid.addEventListener('click', function(e) {
          var chip = e.target.closest ? e.target.closest('.dub-chip') : null;
          if (!chip) return;
          var code = chip.getAttribute('data-code');
          var l = byCode[code];
          if (!l) return;
          var wasPlaying = chip.classList.contains('playing');
          stopSpeech();
          if (wasPlaying) return;
          if (l.status !== 'live') {
            chip.classList.add('flash');
            setTimeout(function() { chip.classList.remove('flash'); }, 700);
            if (dubStatus) dubStatus.innerHTML = '<b>' + l.name + '</b> dub is releasing soon - English and हिन्दी play now.';
            return;
          }
          if (speakText(l.text, l.bcp, function() {
            chip.classList.remove('playing');
            if (dubStatus) dubStatus.textContent = dubStatus.getAttribute('data-idle');
          })) {
            chip.classList.add('playing');
            if (dubStatus) dubStatus.innerHTML = 'Now dubbing in <b>' + l.name + '</b>…';
          }
        });
      }
    });
  </script>
