---
import PitchLayout from '../layouts/PitchLayout.astro';
---
<PitchLayout
  title="Sagar Ahuja - Sarvam AI"
  description="Sarvam won the model race. Here is how it wins the product race. An outsider's product thesis on closing the adoption gap, by Sagar Ahuja."
  slug="sarvam"
  fonts="Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400&family=Hanken+Grotesk:wght@400;500;600;700;800&family=Space+Mono:wght@400;700"
  ogImage="/firstclub/sagar-4.jpg"
>
  <style slot="head" is:global>
    :root {
      --sv-bg: #FCFBFA;
      --sv-surface: #FFFFFF;
      --sv-ink: #3D2B1A;
      --sv-ink-soft: #6B5A48;
      --sv-secondary: #7A6B5A;
      --sv-muted: #A99C8C;
      --sv-border: #ECE6DD;
      --sv-line: #E5DDD2;
      --sv-saffron: #818CF8;
      --sv-magenta: #6366F1;
      --sv-violet: #4F46E5;
      --sv-grad: linear-gradient(105deg, #4F46E5 0%, #6366F1 50%, #818CF8 100%);
      --sv-grad-soft: linear-gradient(135deg, rgba(99,102,241,0.10) 0%, rgba(129,140,248,0.12) 100%);
      --sv-ink-block: #1E2033;
      --sv-radius: 10px;
      --sv-radius-lg: 18px;
      --sv-radius-pill: 999px;
      --sv-ease: cubic-bezier(0.16, 1, 0.3, 1);
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    html { -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; scroll-behavior: smooth; }
    body {
      font-family: 'Hanken Grotesk', -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
      background: var(--sv-bg);
      color: var(--sv-ink);
      font-size: 15px;
      line-height: 1.6;
      font-weight: 400;
    }
    .sv-page { max-width: 1180px; margin: 0 auto; padding: 28px 20px 72px; }
    @media (min-width: 720px) { .sv-page { padding: 44px 32px 96px; } }
    @media (max-width: 420px) { .sv-page { padding: 22px 14px 64px; } }

    strong.k {
      font-weight: 700;
      background: var(--sv-grad);
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
      white-space: nowrap;
    }
    em.c { color: var(--sv-violet); font-style: italic; font-weight: 500; }

    .sv-eyebrow {
      font-family: 'Hanken Grotesk', sans-serif;
      font-size: 11.5px;
      font-weight: 600;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      background: var(--sv-grad);
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
      display: inline-block;
    }

    .reveal { opacity: 0; transform: translateY(20px); transition: opacity 0.7s var(--sv-ease), transform 0.7s var(--sv-ease); }
    .reveal.visible { opacity: 1; transform: translateY(0); }
    .reveal-stagger > * { opacity: 0; transform: translateY(16px); transition: opacity 0.55s var(--sv-ease), transform 0.55s var(--sv-ease); }
    .reveal-stagger.visible > *:nth-child(1) { transition-delay: 0.0s; }
    .reveal-stagger.visible > *:nth-child(2) { transition-delay: 0.10s; }
    .reveal-stagger.visible > *:nth-child(3) { transition-delay: 0.20s; }
    .reveal-stagger.visible > *:nth-child(4) { transition-delay: 0.30s; }
    .reveal-stagger.visible > * { opacity: 1; transform: translateY(0); }
    @media (prefers-reduced-motion: reduce) {
      .reveal, .reveal-stagger > * { opacity: 1; transform: none; transition: none; }
    }

    /* ===== Header ===== */
    .sv-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 24px;
      padding-bottom: 18px;
      border-bottom: 1px solid var(--sv-line);
      margin-bottom: 8px;
      flex-wrap: wrap;
      position: relative;
    }
    .sv-header::after {
      content: '';
      position: absolute;
      left: 0;
      bottom: -1px;
      width: 120px;
      height: 2px;
      background: var(--sv-grad);
    }
    .sv-header .name-block .name {
      font-family: 'Hanken Grotesk', sans-serif;
      font-size: 22px;
      font-weight: 600;
      color: var(--sv-ink);
      letter-spacing: -0.02em;
      margin-bottom: 4px;
    }
    .sv-header .name-block .role {
      font-size: 10.5px;
      font-weight: 600;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--sv-secondary);
      margin-bottom: 6px;
    }
    .sv-header .name-block .website a {
      font-size: 13px;
      font-weight: 500;
      color: var(--sv-ink);
      text-decoration: none;
      border-bottom: 1px solid rgba(24,19,15,0.22);
      transition: border-color 0.15s ease;
    }
    .sv-header .name-block .website a:hover { border-color: var(--sv-magenta); }
    .sv-header .contact-block {
      text-align: right;
      font-size: 12px;
      color: var(--sv-secondary);
      line-height: 1.7;
    }
    .sv-header .contact-block a { color: var(--sv-secondary); text-decoration: none; transition: color 0.15s ease; }
    .sv-header .contact-block a:hover { color: var(--sv-magenta); }
    @media (max-width: 540px) { .sv-header .contact-block { text-align: left; } }

    /* ===== Top hero line ===== */
    .sv-hero {
      margin: 30px 0 6px;
    }
    .sv-hero .tag-row { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; margin-bottom: 16px; }
    .sv-tag {
      display: inline-flex; align-items: center; gap: 6px;
      font-family: 'Space Mono', monospace;
      font-size: 11px; font-weight: 700; letter-spacing: 0.04em;
      text-transform: uppercase;
      padding: 5px 11px; border-radius: var(--sv-radius-pill);
      border: 1px solid var(--sv-border); background: var(--sv-surface); color: var(--sv-secondary);
    }
    .sv-tag .dot { width: 7px; height: 7px; border-radius: 50%; background: var(--sv-grad); }
    .sv-hero h1 {
      font-family: 'Fraunces', Georgia, serif;
      font-optical-sizing: auto;
      font-size: 36px;
      line-height: 1.06;
      font-weight: 500;
      letter-spacing: -0.02em;
      color: var(--sv-ink);
      max-width: 16ch;
    }
    @media (min-width: 720px) { .sv-hero h1 { font-size: 52px; } }
    .sv-hero h1 .grad {
      background: var(--sv-grad);
      -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;
    }
    .sv-hero .sub {
      margin-top: 16px;
      font-size: 16px;
      line-height: 1.6;
      color: var(--sv-secondary);
      max-width: 58ch;
    }
    .sv-hero .sub strong { color: var(--sv-ink); font-weight: 600; }

    /* ===== Split layout ===== */
    .sv-split { display: block; margin-top: 36px; }
    @media (min-width: 960px) {
      .sv-split {
        display: grid;
        grid-template-columns: minmax(0, 380px) minmax(0, 1fr);
        gap: 40px;
        align-items: start;
      }
    }
    .sv-split-left { margin-bottom: 36px; }
    @media (min-width: 960px) {
      .sv-split-left { margin-bottom: 0; position: sticky; top: 28px; }
    }

    /* ===== Playground device ===== */
    .sv-pg {
      background: var(--sv-surface);
      border: 1px solid var(--sv-border);
      border-radius: var(--sv-radius-lg);
      overflow: hidden;
      box-shadow: 0 2px 8px rgba(24,19,15,0.04), 0 22px 50px rgba(24,19,15,0.10);
    }
    .sv-pg-chrome {
      display: flex; align-items: center; gap: 10px;
      padding: 11px 14px;
      border-bottom: 1px solid var(--sv-border);
      background: #fff;
    }
    .sv-pg-chrome .dots { display: flex; gap: 6px; }
    .sv-pg-chrome .dots span { width: 10px; height: 10px; border-radius: 50%; background: var(--sv-line); }
    .sv-pg-chrome .dots span:first-child { background: #EA580C; }
    .sv-pg-brand {
      flex: 1; text-align: center;
      font-family: 'Hanken Grotesk', sans-serif;
      font-size: 12.5px; font-weight: 600; letter-spacing: 0.01em;
      color: var(--sv-ink);
      display: inline-flex; align-items: center; justify-content: center; gap: 7px;
    }
    .sv-pg-brand .logo { width: 16px; height: 16px; border-radius: 5px; background: var(--sv-grad); display: inline-block; }
    .sv-pg-chrome .live {
      font-family: 'Space Mono', monospace; font-size: 9.5px; font-weight: 700;
      color: var(--sv-secondary); letter-spacing: 0.06em; text-transform: uppercase;
      display: inline-flex; align-items: center; gap: 5px;
    }
    .sv-pg-chrome .live::before { content: ''; width: 6px; height: 6px; border-radius: 50%; background: #16A34A; box-shadow: 0 0 0 0 rgba(22,163,74,0.5); animation: svPulse 2s infinite; }
    @keyframes svPulse { 0%{box-shadow:0 0 0 0 rgba(22,163,74,0.5);} 70%{box-shadow:0 0 0 6px rgba(22,163,74,0);} 100%{box-shadow:0 0 0 0 rgba(22,163,74,0);} }
    @media (prefers-reduced-motion: reduce) { .sv-pg-chrome .live::before { animation: none; } }

    /* model selector + language row */
    .sv-pg-bar {
      display: flex; align-items: center; justify-content: space-between; gap: 10px;
      padding: 10px 14px;
      border-bottom: 1px solid var(--sv-border);
      background: var(--sv-grad-soft);
    }
    .sv-model-pill {
      display: inline-flex; align-items: center; gap: 7px;
      padding: 5px 10px; border-radius: var(--sv-radius-pill);
      background: #fff; border: 1px solid var(--sv-border);
      font-family: 'Space Mono', monospace; font-size: 11.5px; font-weight: 700; color: var(--sv-ink);
    }
    .sv-model-pill .spark { width: 13px; height: 13px; color: var(--sv-magenta); }
    .sv-model-pill .chev { color: var(--sv-muted); font-size: 10px; }
    .sv-langs { display: flex; gap: 4px; }
    .sv-lang {
      font-family: 'Hanken Grotesk', sans-serif;
      font-size: 11.5px; font-weight: 600;
      padding: 4px 8px; border-radius: 7px;
      border: 1px solid transparent; background: transparent; color: var(--sv-secondary);
      cursor: pointer; transition: all 0.18s var(--sv-ease);
    }
    .sv-lang:hover { color: var(--sv-ink); }
    .sv-lang.active { background: #fff; border-color: var(--sv-border); color: var(--sv-ink); box-shadow: 0 1px 3px rgba(24,19,15,0.06); }

    /* chat thread */
    .sv-chat { padding: 18px 14px 14px; display: flex; flex-direction: column; gap: 14px; background: linear-gradient(180deg, #fff 0%, #FCFAF7 100%); }
    .sv-msg { display: flex; gap: 10px; align-items: flex-start; }
    .sv-msg .av {
      width: 30px; height: 30px; border-radius: 9px; flex-shrink: 0;
      display: flex; align-items: center; justify-content: center;
      font-family: 'Hanken Grotesk', sans-serif; font-size: 12px; font-weight: 700;
    }
    .sv-msg.user .av { background: #F0ECE5; color: var(--sv-secondary); }
    .sv-msg.bot .av { background: var(--sv-grad); color: #fff; overflow: hidden; }
    .sv-msg.bot .av img { width: 100%; height: 100%; object-fit: cover; }
    .sv-bubble {
      border-radius: 13px; padding: 11px 14px; font-size: 13.5px; line-height: 1.55;
      max-width: 100%;
    }
    .sv-msg.user .sv-bubble { background: #F4F0EA; color: var(--sv-ink); border-top-left-radius: 4px; }
    .sv-msg.bot .sv-bubble { background: #fff; border: 1px solid var(--sv-border); color: var(--sv-ink); border-top-left-radius: 4px; box-shadow: 0 2px 8px rgba(24,19,15,0.04); }
    .sv-bubble .greet { font-family: 'Hanken Grotesk', sans-serif; font-weight: 600; color: var(--sv-magenta); }
    .sv-bubble p { margin: 0 0 8px; }
    .sv-bubble p:last-child { margin-bottom: 0; }
    .sv-bubble strong { font-weight: 600; }
    .sv-answer-list { list-style: none; margin: 8px 0 2px; padding: 0; display: flex; flex-direction: column; gap: 6px; }
    .sv-answer-list li {
      font-size: 12.5px; font-weight: 500; color: var(--sv-ink);
      padding: 6px 10px 6px 30px; background: var(--sv-grad-soft); border-radius: 8px; position: relative;
    }
    .sv-answer-list li b { font-weight: 700; }
    .sv-answer-list li .n {
      position: absolute; left: 9px; top: 50%; transform: translateY(-50%);
      font-family: 'Space Mono', monospace; font-size: 10px; font-weight: 700;
      background: var(--sv-grad); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;
    }
    /* voice waveform under bot answer */
    .sv-wave { display: flex; align-items: center; gap: 8px; margin-top: 10px; padding-top: 10px; border-top: 1px dashed var(--sv-border); }
    .sv-wave .mic { width: 14px; height: 14px; color: var(--sv-magenta); flex-shrink: 0; }
    .sv-wave .bars { display: flex; align-items: center; gap: 2px; height: 18px; }
    .sv-wave .bars span { width: 2.5px; border-radius: 2px; background: var(--sv-grad); height: 5px; animation: svBar 1.1s ease-in-out infinite; }
    .sv-wave .bars span:nth-child(2){animation-delay:.1s} .sv-wave .bars span:nth-child(3){animation-delay:.2s}
    .sv-wave .bars span:nth-child(4){animation-delay:.3s} .sv-wave .bars span:nth-child(5){animation-delay:.15s}
    .sv-wave .bars span:nth-child(6){animation-delay:.25s} .sv-wave .bars span:nth-child(7){animation-delay:.05s}
    .sv-wave .bars span:nth-child(8){animation-delay:.35s} .sv-wave .bars span:nth-child(9){animation-delay:.2s}
    .sv-wave .bars span:nth-child(10){animation-delay:.1s} .sv-wave .bars span:nth-child(11){animation-delay:.3s}
    .sv-wave .bars span:nth-child(12){animation-delay:.18s}
    @keyframes svBar { 0%,100%{height:5px} 50%{height:17px} }
    @media (prefers-reduced-motion: reduce) { .sv-wave .bars span { animation: none; height: 11px; } }
    .sv-wave .cap { font-family: 'Space Mono', monospace; font-size: 9.5px; color: var(--sv-muted); letter-spacing: 0.03em; }

    /* prompt bar */
    .sv-prompt {
      display: flex; align-items: center; gap: 8px;
      margin: 4px 12px 14px; padding: 9px 9px 9px 14px;
      border: 1px solid var(--sv-border); border-radius: var(--sv-radius-pill); background: #fff;
    }
    .sv-prompt .ph { flex: 1; font-size: 12.5px; color: var(--sv-muted); }
    .sv-prompt .send {
      width: 30px; height: 30px; border-radius: 50%; border: none; cursor: default;
      background: var(--sv-grad); color: #fff; display: inline-flex; align-items: center; justify-content: center;
    }
    .sv-prompt .send svg { width: 14px; height: 14px; }

    /* ===== Model card (the "spec sheet") ===== */
    .sv-card {
      margin: 0; border-top: 1px solid var(--sv-border);
      background: #FCFAF7;
    }
    .sv-card-head { padding: 16px 16px 12px; display: flex; align-items: center; gap: 12px; }
    .sv-card-head .ava {
      width: 46px; height: 46px; border-radius: 12px; overflow: hidden; flex-shrink: 0;
      border: 2px solid #fff; box-shadow: 0 2px 8px rgba(24,19,15,0.12);
    }
    .sv-card-head .ava img { width: 100%; height: 100%; object-fit: cover; }
    .sv-card-head .meta { flex: 1; min-width: 0; }
    .sv-card-head .meta .nm { font-family: 'Hanken Grotesk', sans-serif; font-size: 16px; font-weight: 600; color: var(--sv-ink); letter-spacing: -0.01em; }
    .sv-card-head .meta .ver { font-family: 'Space Mono', monospace; font-size: 11px; color: var(--sv-secondary); margin-top: 2px; }
    .sv-card-head .ready {
      display: inline-flex; align-items: center; gap: 4px; flex-shrink: 0;
      font-family: 'Space Mono', monospace; font-size: 9.5px; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase;
      color: #15803D; background: rgba(22,163,74,0.12); padding: 4px 8px; border-radius: var(--sv-radius-pill);
    }
    .sv-card-head .ready svg { width: 11px; height: 11px; }

    .sv-card-badges { display: flex; flex-wrap: wrap; gap: 6px; padding: 0 16px 12px; }
    .sv-badge {
      font-family: 'Space Mono', monospace; font-size: 10px; font-weight: 700; letter-spacing: 0.02em;
      color: var(--sv-secondary); background: #fff; border: 1px solid var(--sv-border);
      padding: 4px 9px; border-radius: var(--sv-radius-pill);
      display: inline-flex; align-items: center; gap: 5px;
    }
    .sv-badge svg { width: 11px; height: 11px; color: var(--sv-magenta); }

    .sv-evals { padding: 4px 16px 6px; }
    .sv-eval-title {
      font-family: 'Space Mono', monospace; font-size: 10px; font-weight: 700; letter-spacing: 0.12em;
      text-transform: uppercase; color: var(--sv-muted); padding: 8px 0 6px;
    }
    .sv-eval-row {
      display: grid; grid-template-columns: 1.3fr auto auto; gap: 10px; align-items: center;
      padding: 9px 0; border-bottom: 1px dashed var(--sv-border); font-size: 12.5px;
    }
    .sv-eval-row:last-child { border-bottom: none; }
    .sv-eval-row .t { color: var(--sv-secondary); font-weight: 500; }
    .sv-eval-row .v { font-family: 'Space Mono', monospace; color: var(--sv-ink); font-weight: 700; text-align: right; }
    .sv-eval-row .s { display: inline-flex; align-items: center; gap: 3px; color: #15803D; font-size: 10px; font-weight: 700; font-family: 'Space Mono', monospace; }
    .sv-eval-row .s svg { width: 12px; height: 12px; }
    @media (max-width: 380px) { .sv-eval-row { grid-template-columns: 1.2fr auto auto; gap: 7px; font-size: 11.5px; } }

    .sv-card-foot { padding: 14px 16px 18px; border-top: 1px solid var(--sv-border); background: #fff; }
    .sv-deploy {
      display: inline-flex; align-items: center; justify-content: center; gap: 8px; width: 100%;
      padding: 15px 22px; border: none; border-radius: var(--sv-radius-pill); cursor: pointer;
      background: var(--sv-grad); color: #fff; text-decoration: none;
      font-family: 'Hanken Grotesk', sans-serif; font-size: 15px; font-weight: 600;
      box-shadow: 0 6px 18px rgba(99,102,241,0.28);
      transition: transform 0.18s var(--sv-ease), box-shadow 0.18s var(--sv-ease);
    }
    .sv-deploy:hover { transform: translateY(-1px); box-shadow: 0 9px 24px rgba(99,102,241,0.34); }
    .sv-deploy:active { transform: translateY(0); }
    .sv-deploy svg { width: 17px; height: 17px; }
    .sv-secondary-link {
      display: inline-flex; align-items: center; justify-content: center; gap: 7px; width: 100%;
      margin-top: 10px; padding: 11px 16px; border-radius: var(--sv-radius-pill);
      border: 1px solid var(--sv-border); background: #fff; color: var(--sv-ink);
      font-size: 13px; font-weight: 600; text-decoration: none;
      transition: border-color 0.18s ease, transform 0.18s ease;
    }
    .sv-secondary-link:hover { border-color: var(--sv-magenta); transform: translateY(-1px); }
    .sv-secondary-link svg { width: 14px; height: 14px; color: var(--sv-secondary); }
    .sv-card-note { font-family: 'Space Mono', monospace; font-size: 10px; color: var(--sv-muted); text-align: center; margin-top: 12px; line-height: 1.5; }

    /* ===== Section heads ===== */
    .sv-section-head { margin-top: 8px; margin-bottom: 14px; }
    .sv-split-right > .sv-section-head:first-child { margin-top: 0; }
    .sv-section-head .eyebrow-row { display: flex; align-items: center; gap: 14px; margin-bottom: 10px; }
    .sv-section-head .eyebrow-row::after { content: ''; flex: 1; height: 1px; background: linear-gradient(90deg, rgba(99,102,241,0.5) 0%, transparent 100%); }
    .sv-section-head h2 {
      font-family: 'Fraunces', Georgia, serif; font-optical-sizing: auto; font-weight: 500; font-size: 27px; line-height: 1.16;
      color: var(--sv-ink); letter-spacing: -0.015em;
    }
    @media (min-width: 720px) { .sv-section-head h2 { font-size: 32px; } }
    .sv-section-head h2 .grad { background: var(--sv-grad); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; }

    /* ===== Framing block ===== */
    .sv-framing {
      margin: 0 0 26px; padding: 22px 24px;
      background: var(--sv-ink-block); border-radius: var(--sv-radius-lg);
      position: relative; overflow: hidden;
    }
    .sv-framing::before {
      content: ''; position: absolute; inset: 0;
      background: radial-gradient(circle at 100% 0%, rgba(99,102,241,0.22) 0%, transparent 45%), radial-gradient(circle at 0% 100%, rgba(129,140,248,0.20) 0%, transparent 45%);
      pointer-events: none;
    }
    .sv-framing .quote {
      position: relative;
      font-family: 'Fraunces', Georgia, serif; font-optical-sizing: auto; font-size: 20px; font-weight: 500; line-height: 1.4;
      color: #fff; letter-spacing: -0.01em; margin-bottom: 12px;
    }
    @media (min-width: 720px) { .sv-framing .quote { font-size: 22px; } }
    .sv-framing .quote .grad { background: var(--sv-grad); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; }
    .sv-framing .tail { position: relative; font-size: 13px; color: rgba(255,255,255,0.62); line-height: 1.6; }
    .sv-framing .tail strong { color: #fff; font-weight: 600; }

    /* ===== Bet cards ===== */
    .sv-bet {
      background: var(--sv-surface); border: 1px solid var(--sv-border); border-radius: var(--sv-radius-lg);
      padding: 24px 24px 22px; margin-bottom: 18px; position: relative; overflow: hidden;
      transition: transform 0.3s var(--sv-ease), box-shadow 0.3s var(--sv-ease);
    }
    .sv-bet::before { content: ''; position: absolute; top: 0; left: 0; width: 4px; height: 100%; background: var(--sv-grad); }
    .sv-bet:hover { transform: translateY(-2px); box-shadow: 0 14px 34px rgba(24,19,15,0.08); }
    @media (min-width: 720px) { .sv-bet { padding: 28px 30px 26px; } }

    .sv-bet .bet-head { display: flex; align-items: flex-start; gap: 14px; margin-bottom: 18px; }
    .sv-bet .bet-icon {
