      if (sel) {
        LANGS.forEach(function(l) {
          var o = document.createElement('option');
          o.value = l.code; o.textContent = l.name + (l.status === 'soon' ? ' · soon' : '');
          sel.appendChild(o);
        });
        sel.value = 'en';
      }

      function chipLabel(s) { var k = SUPPORTED[curLangCode] ? curLangCode : 'en'; return s.label[k] || s.label.en; }
      function buildChips() {
        if (!chipsEl) return;
        chipsEl.innerHTML = '';
        SCENARIOS.forEach(function(s) {
          var b = document.createElement('button');
          b.type = 'button';
          b.className = 'chip' + (s.id === curScenarioId ? ' active' : '');
          b.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">' + ICONS[s.icon] + '</svg>' + chipLabel(s);
          b.addEventListener('click', function() {
            curScenarioId = s.id; stopSpeech(); render();
            if (window.posthog && window.posthog.capture) window.posthog.capture('saathi_scenario', { scenario: s.id, lang: curLangCode });
          });
          chipsEl.appendChild(b);
        });
      }

      function answerText(scn, code) {
        var lines = scn.a[code] || []; var lead = scn.lead[code] || '';
        return (lead + '. ' + lines.join('. ')).replace(/<[^>]+>/g, '');
      }

      function render() {
        if (!chatEl) return;
        var scn = SCENARIOS.filter(function(s){ return s.id === curScenarioId; })[0];
        var live = SUPPORTED[curLangCode];
        var qLang = live ? curLangCode : 'en';
        chatEl.innerHTML = '';

        var u = document.createElement('div');
        u.className = 'bubble user';
        u.innerHTML = scn.q[qLang] + '<span class="t">09:24</span>';
        chatEl.appendChild(u);

        var b = document.createElement('div');
        b.className = 'bubble bot';
        if (live) {
          var items = scn.a[curLangCode].map(function(li) {
            return '<li><svg class="ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg><span>' + li + '</span></li>';
          }).join('');
          b.innerHTML = '<div class="bot-lead">' + scn.lead[curLangCode] + '</div>'
            + '<ul class="check">' + items + '</ul>'
            + '<button class="listen" id="ya-listen" type="button">'
            + '<span class="pi"><svg class="ico-play" viewBox="0 0 24 24" fill="currentColor"><polygon points="6 4 20 12 6 20 6 4"/></svg>'
            + '<svg class="ico-pause" viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="5" width="4" height="14"/><rect x="14" y="5" width="4" height="14"/></svg></span>'
            + (curLangCode === 'hi' ? 'सुनिए' : 'Listen')
            + '<span class="wv" aria-hidden="true"><span></span><span></span><span></span><span></span><span></span></span>'
            + '</button><span class="t">09:24</span>';
        } else {
          var l = byCode[curLangCode];
          b.innerHTML = '<div class="bot-lead" style="font-family:Bricolage Grotesque,sans-serif;font-size:22px;color:var(--lime);">' + l.greet + '</div>'
            + '<div style="font-size:13px;color:var(--dim);line-height:1.5;">Saathi will speak <b style="color:var(--text)">' + l.name + '</b> soon. English and हिन्दी are live now. Switch the language to try them.</div>'
            + '<span class="t">09:24</span>';
        }
        chatEl.appendChild(b);

        var listen = document.getElementById('ya-listen');
        if (listen) listen.addEventListener('click', function() {
          if (listen.classList.contains('playing')) { stopSpeech(); return; }
          speak(answerText(scn, curLangCode), byCode[curLangCode].bcp, listen);
        });
        buildChips();
      }

      var activeBtn = null;
      function stopSpeech() {
        if (window.speechSynthesis) { try { window.speechSynthesis.cancel(); } catch (e) {} }
        if (activeBtn) { activeBtn.classList.remove('playing'); activeBtn = null; }
      }
      function pickVoice(bcp) {
        if (!window.speechSynthesis) return null;
        var vs = window.speechSynthesis.getVoices() || [];
        var exact = vs.filter(function(v){ return v.lang === bcp; })[0];
        if (exact) return exact;
        var base = bcp.split('-')[0];
        return vs.filter(function(v){ return v.lang && v.lang.indexOf(base) === 0; })[0] || null;
      }
      function speak(text, bcp, btn) {
        if (!('speechSynthesis' in window)) return;
        stopSpeech();
        var u = new SpeechSynthesisUtterance(text);
        u.lang = bcp; u.rate = 0.97;
        var v = pickVoice(bcp); if (v) u.voice = v;
        u.onend = function() { btn.classList.remove('playing'); activeBtn = null; };
        u.onerror = function() { btn.classList.remove('playing'); activeBtn = null; };
        window.speechSynthesis.speak(u);
        btn.classList.add('playing'); activeBtn = btn;
        if (window.posthog && window.posthog.capture) window.posthog.capture('saathi_listen', { scenario: curScenarioId, lang: curLangCode });
      }
      if (window.speechSynthesis) { window.speechSynthesis.onvoiceschanged = function(){}; }

      if (sel) sel.addEventListener('change', function() {
        curLangCode = sel.value; stopSpeech(); render();
        if (window.posthog && window.posthog.capture) window.posthog.capture('saathi_lang', { lang: curLangCode });
      });

      render();
    });
  </script>
</PitchLayout>
