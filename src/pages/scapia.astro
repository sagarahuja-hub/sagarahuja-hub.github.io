        document.querySelectorAll('.reveal, .reveal-stagger').forEach(function(el) { el.classList.add('visible'); });
      }

      // ----- Yatra Saathi demo data -----
      // English + Hindi are written out and speak live. Other languages show the
      // verified greeting only - real translations should ship verified, not faked.
      var LANGS = [
        { code: 'en', name: 'English', bcp: 'en-IN', status: 'live' },
        { code: 'hi', name: 'हिन्दी', bcp: 'hi-IN', status: 'live' },
        { code: 'mr', name: 'मराठी', bcp: 'mr-IN', status: 'soon', greet: 'नमस्कार' },
        { code: 'ta', name: 'தமிழ்', bcp: 'ta-IN', status: 'soon', greet: 'வணக்கம்' },
        { code: 'te', name: 'తెలుగు', bcp: 'te-IN', status: 'soon', greet: 'నమస్తే' },
        { code: 'kn', name: 'ಕನ್ನಡ', bcp: 'kn-IN', status: 'soon', greet: 'ನಮಸ್ಕಾರ' },
        { code: 'bn', name: 'বাংলা', bcp: 'bn-IN', status: 'soon', greet: 'নমস্কার' }
      ];

      var SCENARIOS = [
        {
          id: 'first', icon: 'plane',
          label: { en: 'My first flight', hi: 'पहली उड़ान' },
          q: {
            en: 'I am flying for the very first time, going to Tirupati. What should I keep ready?',
            hi: 'मैं ज़िंदगी में पहली बार हवाई जहाज़ में बैठ रहा हूँ, तिरुपति जा रहा हूँ। क्या तैयार रखूँ?'
          },
          lead: { en: 'Do not worry, I will be with you the whole way.', hi: 'चिंता मत कीजिए, मैं पूरे सफ़र में आपके साथ हूँ।' },
          a: {
            en: [
              'Carry one government photo ID. Your <b>Aadhaar</b> is enough.',
              'Reach the airport <b>2 hours before</b>. I will remind you tonight.',
              'At security, take out phone, keys and metal. I will walk you through the gate.',
              'Your <b>lounge is free</b> with Scapia. Rest and eat there before the flight.',
              'Booked on <b>Scapia Coins</b>. Nothing more to pay at Tirupati.'
            ],
            hi: [
              'एक सरकारी फोटो पहचान-पत्र रखें। <b>आधार</b> काफ़ी है।',
              'हवाई अड्डे <b>2 घंटे पहले</b> पहुँचें। मैं आज रात याद दिला दूँगी।',
              'जाँच पर फ़ोन, चाबी और धातु बाहर निकालें। मैं गेट तक साथ रहूँगी।',
              '<b>लाउंज Scapia के साथ मुफ़्त</b> है। उड़ान से पहले वहाँ आराम करें और खाएँ।',
              '<b>Scapia Coins</b> से बुक है। तिरुपति में और कुछ नहीं देना।'
            ]
          }
        },
        {
          id: 'delay', icon: 'clock',
          label: { en: 'Flight delayed', hi: 'उड़ान में देरी' },
          q: {
            en: 'My flight is delayed by 3 hours. What do I do now?',
            hi: 'मेरी उड़ान 3 घंटे लेट हो गई है। अब मैं क्या करूँ?'
          },
          lead: { en: 'You are not stranded. I am already on it.', hi: 'आप फँसे नहीं हैं। मैं पहले से संभाल रही हूँ।' },
          a: {
            en: [
              'Wait in the <b>lounge</b>. Your Scapia card lets you in free.',
              'A <b>delay payout in Scapia Coins</b> is already on its way to you.',
              'I am tracking the flight live and will tell you the moment it boards.',
              'If it is cancelled, I will <b>rebook the next flight</b> for you, free.'
            ],
            hi: [
              '<b>लाउंज</b> में इंतज़ार करें। Scapia कार्ड से मुफ़्त प्रवेश है।',
              'देरी का <b>Scapia Coins मुआवज़ा</b> पहले ही आपको भेजा जा रहा है।',
              'मैं उड़ान पर नज़र रखे हूँ, बोर्डिंग होते ही बता दूँगी।',
              'अगर रद्द हुई, तो मैं <b>अगली उड़ान मुफ़्त बुक</b> कर दूँगी।'
            ]
          }
        },
        {
          id: 'budget', icon: 'wallet',
          label: { en: 'Trip cost', hi: 'खर्च कितना' },
          q: {
            en: 'How much will the whole Tirupati trip cost me?',
            hi: 'पूरी तिरुपति यात्रा में मेरा कितना खर्च होगा?'
          },
          lead: { en: 'Here is the full picture, no surprises.', hi: 'पूरा हिसाब यहाँ है, कोई छिपी बात नहीं।' },
          a: {
            en: [
              'Flights and stay come to about <b>₹11,000</b> together.',
              'Pay over <b>3 months</b>. No cost, no hidden charges.',
              'You earn <b>1,100 Scapia Coins</b> back on this trip.',
              'I can add <b>darshan booking</b> and a cab to the temple too.'
            ],
            hi: [
              'उड़ान और ठहरना मिलाकर लगभग <b>₹11,000</b>।',
              '<b>3 महीनों</b> में चुकाएँ। कोई शुल्क नहीं, कोई छिपा खर्च नहीं।',
              'इस यात्रा पर आपको <b>1,100 Scapia Coins</b> वापस मिलेंगे।',
              '<b>दर्शन बुकिंग</b> और मंदिर तक कैब, दोनों मैं जोड़ सकती हूँ।'
            ]
          }
        }
      ];

      var ICONS = {
        plane: '<path d="M17.8 19.2 16 11l3.5-3.5a2.1 2.1 0 0 0-3-3L13 8 4.8 6.2a.5.5 0 0 0-.5.8L8 11l-2 2-2-.5a.5.5 0 0 0-.5.8L6 16l1.7 2.5a.5.5 0 0 0 .8-.5L8 16l2-2 3.4 3.7a.5.5 0 0 0 .8-.5z"/>',
        clock: '<circle cx="12" cy="12" r="9"/><polyline points="12 7 12 12 15 14"/>',
        wallet: '<path d="M21 12V7H5a2 2 0 0 1 0-4h14v4"/><path d="M3 5v14a2 2 0 0 0 2 2h16v-5"/><path d="M18 12a2 2 0 0 0 0 4h4v-4z"/>'
      };

      var SUPPORTED = { en: true, hi: true };

      var sel = document.getElementById('ya-lang');
      var chatEl = document.getElementById('ya-chat');
      var chipsEl = document.getElementById('ya-chips');
      var byCode = {}; LANGS.forEach(function(l){ byCode[l.code] = l; });

      var curLangCode = 'en';
      var curScenarioId = 'first';

      // populate language select
      if (sel) {
        LANGS.forEach(function(l) {
          var o = document.createElement('option');
          o.value = l.code; o.textContent = l.name + (l.status === 'soon' ? ' · soon' : '');
          sel.appendChild(o);
        });
        sel.value = 'en';
      }

      // populate scenario chips
      function chipLabel(s) {
        var k = SUPPORTED[curLangCode] ? curLangCode : 'en';
        return s.label[k] || s.label.en;
      }
      function buildChips() {
        if (!chipsEl) return;
        chipsEl.innerHTML = '';
        SCENARIOS.forEach(function(s) {
          var b = document.createElement('button');
          b.type = 'button';
          b.className = 'ya-chip' + (s.id === curScenarioId ? ' active' : '');
          b.setAttribute('data-id', s.id);
          b.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">' + ICONS[s.icon] + '</svg>' + chipLabel(s);
          b.addEventListener('click', function() {
            curScenarioId = s.id;
            stopSpeech();
            render();
            if (window.posthog && window.posthog.capture) window.posthog.capture('saathi_scenario', { scenario: s.id, lang: curLangCode });
          });
          chipsEl.appendChild(b);
        });
      }

      function answerText(scn, code) {
        // strip <b> for speech
        var lines = scn.a[code] || [];
        var lead = scn.lead[code] || '';
        return (lead + '. ' + lines.join('. ')).replace(/<[^>]+>/g, '');
      }

      function render() {
        if (!chatEl) return;
        var scn = SCENARIOS.filter(function(s){ return s.id === curScenarioId; })[0];
        var live = SUPPORTED[curLangCode];
        var qLang = live ? curLangCode : 'en';
        chatEl.innerHTML = '';

        // user bubble
        var u = document.createElement('div');
        u.className = 'ya-bubble user';
        u.innerHTML = scn.q[qLang] + '<span class="t">09:24</span>';
        chatEl.appendChild(u);

        // bot bubble
        var b = document.createElement('div');
        b.className = 'ya-bubble bot';

        if (live) {
          var listItems = scn.a[curLangCode].map(function(li) {
            return '<li><svg class="ic" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg><span>' + li + '</span></li>';
          }).join('');
          b.innerHTML = '<div class="ya-bot-lead">' + scn.lead[curLangCode] + '</div>'
            + '<ul class="ya-check">' + listItems + '</ul>'
            + '<button class="ya-listen" id="ya-listen" type="button">'
            + '<span class="pi"><svg class="ico-play" viewBox="0 0 24 24" fill="currentColor"><polygon points="6 4 20 12 6 20 6 4"/></svg>'
            + '<svg class="ico-pause" viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="5" width="4" height="14"/><rect x="14" y="5" width="4" height="14"/></svg></span>'
            + (curLangCode === 'hi' ? 'सुनिए' : 'Listen')
            + '<span class="ya-wave" aria-hidden="true"><span></span><span></span><span></span><span></span><span></span></span>'
            + '</button>'
            + '<span class="t">09:24</span>';
        } else {
          var l = byCode[curLangCode];
          b.innerHTML = '<div class="ya-bot-lead" style="font-family:Fraunces,Georgia,serif;font-size:21px;">' + l.greet + '</div>'
            + '<div style="font-size:13px;color:var(--ya-secondary);line-height:1.5;">Saathi will speak <b>' + l.name + '</b> soon. English and हिन्दी are live now. Switch the language to try them.</div>'
            + '<span class="t">09:24</span>';
        }
        chatEl.appendChild(b);

        // wire listen button
        var listen = document.getElementById('ya-listen');
        if (listen) {
          listen.addEventListener('click', function() {
            if (listen.classList.contains('playing')) { stopSpeech(); return; }
            speak(answerText(scn, curLangCode), byCode[curLangCode].bcp, listen);
          });
        }
        // rebuild chips to reflect language on labels + active state
        buildChips();
      }

      // ----- Speech (Web Speech API) -----
      var activeBtn = null;
      function stopSpeech() {
        if (window.speechSynthesis) { try { window.speechSynthesis.cancel(); } catch (e) {} }
        if (activeBtn) { activeBtn.classList.remove('playing'); activeBtn = null; }
      }
      function pickVoice(bcp) {
        if (!window.speechSynthesis) return null;
        var vs = window.speechSynthesis.getVoices() || [];
        var exact = vs.filter(function(v){ return v.lang === bcp; })[0];
        if (exact) return exact;
        var base = bcp.split('-')[0];
        return vs.filter(function(v){ return v.lang && v.lang.indexOf(base) === 0; })[0] || null;
      }
      function speak(text, bcp, btn) {
        if (!('speechSynthesis' in window)) { return; }
        stopSpeech();
        var u = new SpeechSynthesisUtterance(text);
        u.lang = bcp; u.rate = 0.97;
        var v = pickVoice(bcp); if (v) u.voice = v;
        u.onend = function() { btn.classList.remove('playing'); activeBtn = null; };
        u.onerror = function() { btn.classList.remove('playing'); activeBtn = null; };
        window.speechSynthesis.speak(u);
        btn.classList.add('playing');
        activeBtn = btn;
        if (window.posthog && window.posthog.capture) window.posthog.capture('saathi_listen', { scenario: curScenarioId, lang: curLangCode });
      }
      // some browsers load voices async
      if (window.speechSynthesis) { window.speechSynthesis.onvoiceschanged = function(){ /* voices ready */ }; }

      if (sel) {
        sel.addEventListener('change', function() {
          curLangCode = sel.value;
          stopSpeech();
          render();
          if (window.posthog && window.posthog.capture) window.posthog.capture('saathi_lang', { lang: curLangCode });
        });
      }

      render();
    });
  </script>
</PitchLayout>
