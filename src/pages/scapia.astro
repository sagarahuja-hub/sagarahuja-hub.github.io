---
import PitchLayout from '../layouts/PitchLayout.astro';
---
<PitchLayout
  title="Sagar Ahuja - Scapia"
  description="Scapia raised $63M to reach the next India. A map to the next ten million travellers: a pilgrimage wedge, a product built for first-time flyers, and Yatra Saathi, a voice-first AI companion. Plotted by Sagar Ahuja."
  slug="scapia"
  fonts="Bricolage+Grotesque:opsz,wght@12..96,500;12..96,600;12..96,700;12..96,800&family=Inter:wght@400;500;600;700&family=Space+Mono:wght@400;700"
  ogImage="/firstclub/sagar-4.jpg"
>
  <style slot="head" is:global>
    :root {
      --bg: #07120F;
      --bg-2: #0B1A16;
      --panel: #0F2620;
      --panel-2: #123029;
      --lime: #C8F94B;
      --lime-deep: #A6E02B;
      --teal: #25D0A8;
      --teal-deep: #14a585;
      --gold: #E9B65A;
      --text: #ECF4ED;
      --dim: #9FB6AE;
      --faint: #647A72;
      --hair: rgba(236,244,237,0.09);
      --hair-lime: rgba(200,249,75,0.20);
      --radius: 14px;
      --radius-lg: 24px;
      --pill: 999px;
      --ease: cubic-bezier(0.16, 1, 0.3, 1);
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    html { -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; scroll-behavior: smooth; }
    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
      background: var(--bg);
      color: var(--text);
      font-size: 15px; line-height: 1.62; font-weight: 400;
      overflow-x: hidden;
    }
    ::selection { background: rgba(200,249,75,0.28); color: #fff; }
    .mono { font-family: 'Space Mono', monospace; }
    strong.k { color: var(--lime); font-weight: 700; }
    em.c { color: var(--teal); font-style: italic; font-weight: 500; }

    .reveal { opacity: 0; transform: translateY(22px); transition: opacity 0.8s var(--ease), transform 0.8s var(--ease); }
    .reveal.visible { opacity: 1; transform: translateY(0); }
    @media (prefers-reduced-motion: reduce) { .reveal { opacity: 1; transform: none; transition: none; } }

    .wrap { width: 100%; max-width: 1080px; margin: 0 auto; padding: 0 22px; }
    .wrap.tight { max-width: 760px; }

    /* ============ Topo background ============ */
    .topo { position: fixed; inset: 0; z-index: 0; pointer-events: none; }
    .topo::before {
      content: ''; position: absolute; inset: 0; opacity: 0.5;
      background:
        radial-gradient(60% 50% at 82% -5%, rgba(37,208,168,0.12) 0%, transparent 60%),
        radial-gradient(55% 45% at 8% 18%, rgba(200,249,75,0.07) 0%, transparent 55%),
        radial-gradient(70% 60% at 50% 108%, rgba(37,208,168,0.10) 0%, transparent 60%);
    }
    .topo::after {
      content: ''; position: absolute; inset: 0; opacity: 0.5;
      background-image: radial-gradient(rgba(236,244,237,0.06) 1px, transparent 1px);
      background-size: 26px 26px;
      mask-image: radial-gradient(circle at 50% 30%, #000 0%, transparent 75%);
      -webkit-mask-image: radial-gradient(circle at 50% 30%, #000 0%, transparent 75%);
    }
    .page { position: relative; z-index: 1; }

    /* ============ Map title strip (not a resume header) ============ */
    .titlebar { display: flex; justify-content: space-between; align-items: center; gap: 16px; padding: 18px 0 0; font-family: 'Space Mono', monospace; font-size: 10.5px; letter-spacing: 0.16em; text-transform: uppercase; color: var(--faint); flex-wrap: wrap; }
    .titlebar .mark { display: inline-flex; align-items: center; gap: 9px; color: var(--dim); }
    .titlebar .mark .compass { width: 16px; height: 16px; color: var(--lime); }
    .titlebar .sig { color: var(--dim); }
    .titlebar .sig b { color: var(--text); font-weight: 700; }

    /* ============ Hero ============ */
    .hero { min-height: 90vh; display: flex; flex-direction: column; justify-content: center; padding: 40px 0 30px; position: relative; }
    .hero .coords { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 26px; }
    .hero .coord { font-family: 'Space Mono', monospace; font-size: 10.5px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: var(--dim); padding: 6px 12px; border: 1px solid var(--hair); border-radius: var(--pill); background: rgba(15,38,32,0.5); display: inline-flex; align-items: center; gap: 7px; }
    .hero .coord .d { width: 6px; height: 6px; border-radius: 50%; background: var(--lime); box-shadow: 0 0 8px var(--lime); }
    .hero .coord .d.teal { background: var(--teal); box-shadow: 0 0 8px var(--teal); }
    .hero h1 { font-family: 'Bricolage Grotesque', sans-serif; font-optical-sizing: auto; font-weight: 700; font-size: 46px; line-height: 0.98; letter-spacing: -0.025em; color: var(--text); max-width: 16ch; }
    @media (min-width: 720px) { .hero h1 { font-size: 86px; } }
    @media (min-width: 980px) { .hero h1 { font-size: 100px; } }
    .hero h1 .lime { color: var(--lime); position: relative; }
    .hero .sub { margin-top: 28px; font-size: 16.5px; line-height: 1.62; color: var(--dim); max-width: 56ch; }
    .hero .sub strong { color: var(--text); font-weight: 600; }
    .hero .sub .hl { color: var(--lime); font-weight: 600; }

    .hero-foot { display: flex; align-items: center; gap: 22px; margin-top: 40px; flex-wrap: wrap; }
    .begin { display: inline-flex; align-items: center; gap: 11px; font-family: 'Space Mono', monospace; font-size: 11px; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: var(--text); }
    .begin .arrowdown { width: 30px; height: 30px; border-radius: 50%; border: 1px solid var(--hair-lime); display: inline-flex; align-items: center; justify-content: center; color: var(--lime); animation: bob 1.8s var(--ease) infinite; }
    .begin .arrowdown svg { width: 14px; height: 14px; }
    @keyframes bob { 0%,100%{transform:translateY(0)} 50%{transform:translateY(4px)} }
    @media (prefers-reduced-motion: reduce){ .begin .arrowdown { animation: none; } }
    .hero-route { flex: 1; min-width: 200px; height: 46px; opacity: 0.8; }
    .hero-route path.dash { stroke-dasharray: 4 7; }

    /* ============ Chapter marker ============ */
    .chapter { display: flex; align-items: baseline; gap: 14px; margin: 0 0 26px; }
    .chapter .no { font-family: 'Space Mono', monospace; font-size: 12px; font-weight: 700; color: var(--lime); letter-spacing: 0.1em; }
    .chapter .lbl { font-family: 'Space Mono', monospace; font-size: 11px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: var(--dim); }
    .chapter .rule { flex: 1; height: 1px; background: linear-gradient(90deg, var(--hair-lime), transparent); align-self: center; }

    /* ============ Yatra Saathi demo ============ */
    .demo { padding: 64px 0 20px; }
    .demo .lead { text-align: center; max-width: 600px; margin: 0 auto 30px; }
    .demo .lead h2 { font-family: 'Bricolage Grotesque', sans-serif; font-weight: 700; font-size: 32px; line-height: 1.05; letter-spacing: -0.02em; color: var(--text); }
    @media (min-width: 720px){ .demo .lead h2 { font-size: 44px; } }
    .demo .lead h2 .lime { color: var(--lime); }
    .demo .lead p { margin-top: 14px; font-size: 14.5px; color: var(--dim); }

    .phone { max-width: 412px; margin: 0 auto; background: #050D0B; border-radius: 34px; padding: 9px; box-shadow: 0 0 0 1px rgba(200,249,75,0.10), 0 30px 80px rgba(0,0,0,0.6), 0 0 60px rgba(37,208,168,0.10); position: relative; }
    .phone::before { content: ''; position: absolute; top: 18px; left: 50%; transform: translateX(-50%); width: 84px; height: 5px; border-radius: 99px; background: rgba(255,255,255,0.16); z-index: 5; }
    .screen { background: #08130F; border-radius: 26px; overflow: hidden; }

    .wa-top { padding: 32px 16px 13px; display: flex; align-items: center; gap: 11px; background: linear-gradient(180deg, #0F2620, #0B1A16); border-bottom: 1px solid rgba(200,249,75,0.12); }
    .wa-av { width: 40px; height: 40px; border-radius: 50%; flex-shrink: 0; background: linear-gradient(135deg, var(--lime), var(--teal)); display: flex; align-items: center; justify-content: center; }
    .wa-av svg { width: 22px; height: 22px; color: #07120F; }
    .wa-meta { flex: 1; min-width: 0; }
    .wa-name { font-size: 15px; font-weight: 700; color: var(--text); display: flex; align-items: center; gap: 6px; }
    .wa-name .v { width: 13px; height: 13px; color: var(--lime); }
    .wa-status { font-size: 11px; color: var(--teal); margin-top: 1px; display: flex; align-items: center; gap: 6px; }
    .wa-status .live { width: 6px; height: 6px; border-radius: 50%; background: var(--lime); box-shadow: 0 0 0 0 rgba(200,249,75,0.6); animation: ring 2s infinite; }
    @keyframes ring { 0%{box-shadow:0 0 0 0 rgba(200,249,75,0.55)} 70%{box-shadow:0 0 0 7px rgba(200,249,75,0)} 100%{box-shadow:0 0 0 0 rgba(200,249,75,0)} }
    @media (prefers-reduced-motion: reduce){ .wa-status .live { animation: none; } }
    .wa-lang { position: relative; flex-shrink: 0; }
    .wa-lang select { appearance: none; -webkit-appearance: none; font-family: 'Inter', sans-serif; font-size: 12px; font-weight: 600; color: var(--text); background: rgba(200,249,75,0.10); border: 1px solid rgba(200,249,75,0.24); border-radius: var(--pill); padding: 6px 26px 6px 12px; cursor: pointer; }
    .wa-lang select option { color: #07120F; background: #ECF4ED; }
    .wa-lang::after { content: '▾'; position: absolute; right: 11px; top: 50%; transform: translateY(-50%); pointer-events: none; color: var(--lime); font-size: 10px; }

    .chat { padding: 16px 13px 13px; min-height: 372px; display: flex; flex-direction: column; gap: 11px;
      background-image: radial-gradient(rgba(200,249,75,0.05) 0.8px, transparent 0.8px); background-size: 18px 18px; }
    .bubble { max-width: 86%; padding: 9px 12px; font-size: 13.5px; line-height: 1.5; border-radius: 15px; animation: pop 0.4s var(--ease) both; }
    @keyframes pop { from{opacity:0;transform:translateY(7px)} to{opacity:1;transform:translateY(0)} }
    @media (prefers-reduced-motion: reduce){ .bubble { animation: none; } }
    .bubble.user { align-self: flex-end; background: linear-gradient(135deg, var(--lime-deep), var(--lime)); color: #07120F; border-bottom-right-radius: 4px; font-weight: 500; }
    .bubble.bot { align-self: flex-start; background: #11302A; color: var(--text); border: 1px solid rgba(236,244,237,0.07); border-bottom-left-radius: 4px; }
    .bubble .t { font-family: 'Space Mono', monospace; font-size: 8.5px; letter-spacing: 0.05em; opacity: 0.45; display: block; text-align: right; margin-top: 4px; }
    .bot-lead { font-weight: 600; margin-bottom: 8px; color: var(--text); }
    .check { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 7px; }
    .check li { display: flex; gap: 8px; align-items: flex-start; font-size: 13px; line-height: 1.45; color: var(--dim); }
    .check li .ic { width: 16px; height: 16px; flex-shrink: 0; margin-top: 1px; color: var(--lime); }
    .check li b { color: var(--text); font-weight: 600; }
    .listen { display: inline-flex; align-items: center; gap: 8px; margin-top: 12px; padding: 7px 14px 7px 8px; border: none; border-radius: var(--pill); background: rgba(200,249,75,0.12); border: 1px solid rgba(200,249,75,0.3); color: var(--lime); font-family: 'Inter', sans-serif; font-size: 12px; font-weight: 700; cursor: pointer; transition: transform 0.16s var(--ease), background 0.16s; }
    .listen:hover { transform: translateY(-1px); background: rgba(200,249,75,0.2); }
    .listen .pi { width: 24px; height: 24px; border-radius: 50%; background: var(--lime); color: #07120F; display: inline-flex; align-items: center; justify-content: center; }
    .listen .pi svg { width: 12px; height: 12px; }
    .listen .ico-pause { display: none; }
    .listen.playing .ico-play { display: none; }
    .listen.playing .ico-pause { display: inline; }
    .wv { display: inline-flex; align-items: center; gap: 2px; height: 14px; }
    .wv span { width: 2.5px; height: 4px; border-radius: 2px; background: var(--lime); }
    .listen.playing .wv span { animation: bar 0.9s ease-in-out infinite; }
    .wv span:nth-child(2n){animation-delay:.12s} .wv span:nth-child(3n){animation-delay:.22s} .wv span:nth-child(4n){animation-delay:.07s}
    @keyframes bar { 0%,100%{height:4px} 50%{height:13px} }
    @media (prefers-reduced-motion: reduce){ .listen.playing .wv span { animation: none; height: 8px; } }

    .chips { display: flex; gap: 7px; padding: 11px 13px 14px; background: #0B1A16; flex-wrap: wrap; border-top: 1px solid rgba(236,244,237,0.06); }
    .chip { flex: 1 1 auto; display: inline-flex; align-items: center; justify-content: center; gap: 6px; padding: 9px 10px; border-radius: var(--pill); border: 1px solid var(--hair); background: rgba(15,38,32,0.6); color: var(--dim); font-size: 12px; font-weight: 600; cursor: pointer; white-space: nowrap; transition: all 0.16s var(--ease); }
    .chip svg { width: 14px; height: 14px; color: var(--lime); flex-shrink: 0; }
    .chip:hover { border-color: var(--hair-lime); color: var(--text); }
    .chip.active { background: var(--lime); border-color: var(--lime); color: #07120F; }
    .chip.active svg { color: #07120F; }
    .demo-note { text-align: center; font-family: 'Space Mono', monospace; font-size: 10px; color: var(--faint); margin-top: 18px; line-height: 1.7; max-width: 52ch; margin-left: auto; margin-right: auto; }

    /* ============ Thesis ============ */
    .thesis { padding: 70px 0 8px; }
    .thesis .quote { font-family: 'Bricolage Grotesque', sans-serif; font-weight: 600; font-size: 26px; line-height: 1.22; letter-spacing: -0.02em; color: var(--text); }
    @media (min-width: 720px){ .thesis .quote { font-size: 38px; } }
    .thesis .quote .lime { color: var(--lime); }
    .thesis .tail { margin-top: 22px; font-size: 15px; line-height: 1.65; color: var(--dim); max-width: 60ch; border-left: 2px solid var(--hair-lime); padding-left: 18px; }
    .thesis .tail strong { color: var(--text); font-weight: 600; }

    /* ============ Route ============ */
    .route { padding: 50px 0 10px; }
    .ways { position: relative; max-width: 1000px; margin: 0 auto; }
    .ways::before { content: ''; position: absolute; left: 50%; top: 4px; bottom: 90px; width: 2px; margin-left: -1px;
      background: linear-gradient(180deg, transparent, var(--lime) 5%, var(--teal) 95%, transparent);
      box-shadow: 0 0 16px rgba(200,249,75,0.35); opacity: 0.55; }
    .way { position: relative; width: 47%; margin-bottom: 54px; }
    .way:nth-child(odd) { margin-right: auto; }
    .way:nth-child(even) { margin-left: auto; }
    .node { position: absolute; top: 6px; width: 22px; height: 22px; border-radius: 50%; background: var(--bg); border: 2px solid var(--lime); box-shadow: 0 0 14px rgba(200,249,75,0.6); display: flex; align-items: center; justify-content: center; }
    .node::after { content: ''; width: 7px; height: 7px; border-radius: 50%; background: var(--lime); }
    .way:nth-child(odd) .node { right: -54px; }
    .way:nth-child(even) .node { left: -54px; }
    .way:nth-child(odd) .connector { position: absolute; right: -44px; top: 16px; width: 34px; height: 1px; background: var(--hair-lime); }
    .way:nth-child(even) .connector { position: absolute; left: -44px; top: 16px; width: 34px; height: 1px; background: var(--hair-lime); }

    .loc { position: relative; background: linear-gradient(180deg, var(--panel), var(--bg-2)); border: 1px solid var(--hair); border-radius: var(--radius-lg); padding: 24px 24px 22px; overflow: hidden; transition: transform 0.3s var(--ease), border-color 0.3s; }
    .loc:hover { transform: translateY(-3px); border-color: var(--hair-lime); }
    .loc .ghost { position: absolute; top: -18px; right: 8px; font-family: 'Bricolage Grotesque', sans-serif; font-weight: 800; font-size: 120px; line-height: 1; color: transparent; -webkit-text-stroke: 1px rgba(200,249,75,0.10); pointer-events: none; }
    .loc .coord { font-family: 'Space Mono', monospace; font-size: 10px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--teal); position: relative; }
    .loc h3 { font-family: 'Bricolage Grotesque', sans-serif; font-weight: 700; font-size: 24px; line-height: 1.1; letter-spacing: -0.02em; color: var(--text); margin-top: 8px; position: relative; }
    @media (min-width: 720px){ .loc h3 { font-size: 27px; } }
    .loc .one { font-size: 14px; color: var(--lime); font-style: italic; margin-top: 8px; position: relative; }
    .loc .gap { font-size: 14px; line-height: 1.62; color: var(--dim); margin-top: 16px; position: relative; }
    .loc .gap strong { color: var(--text); font-weight: 600; }
    .loc .gap em { color: var(--teal); font-style: italic; }
    .loc .build { position: relative; margin-top: 16px; padding: 14px 16px; border-radius: var(--radius); background: rgba(200,249,75,0.07); border: 1px solid rgba(200,249,75,0.18); }
    .loc .build .bl { font-family: 'Space Mono', monospace; font-size: 9.5px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--lime); margin-bottom: 6px; }
    .loc .build p { font-size: 13.5px; line-height: 1.6; color: var(--text); }
    .loc .build p strong { color: var(--lime); font-weight: 600; }
    .loc .win { display: flex; gap: 9px; align-items: flex-start; margin-top: 14px; position: relative; font-size: 13px; line-height: 1.55; color: var(--dim); }
    .loc .win svg { width: 16px; height: 16px; color: var(--teal); flex-shrink: 0; margin-top: 2px; }
    .loc .win strong { color: var(--text); font-weight: 600; }

    .dest { position: relative; max-width: 620px; margin: 12px auto 0; text-align: center; }
    .dest .flag { width: 52px; height: 52px; margin: 0 auto 16px; border-radius: 50%; background: linear-gradient(135deg, var(--lime), var(--teal)); display: flex; align-items: center; justify-content: center; box-shadow: 0 0 30px rgba(200,249,75,0.45); }
    .dest .flag svg { width: 26px; height: 26px; color: #07120F; }
    .dest .dl { font-family: 'Space Mono', monospace; font-size: 10.5px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: var(--teal); margin-bottom: 10px; }
    .dest p { font-family: 'Bricolage Grotesque', sans-serif; font-weight: 600; font-size: 22px; line-height: 1.3; letter-spacing: -0.015em; color: var(--text); }
    @media (min-width: 720px){ .dest p { font-size: 26px; } }
    .dest p .lime { color: var(--lime); }

    @media (max-width: 820px) {
      .ways::before { left: 11px; bottom: 70px; }
      .way { width: 100%; margin-left: 0 !important; margin-right: 0 !important; padding-left: 40px; margin-bottom: 30px; }
      .way .node { left: 1px !important; right: auto !important; }
      .way .connector { display: none; }
      .loc .ghost { font-size: 90px; top: -10px; }
    }

    /* ============ Cartographer (why me) ============ */
    .carto { padding: 78px 0 10px; }
    .carto-panel { background: linear-gradient(135deg, var(--panel), var(--bg-2)); border: 1px solid var(--hair); border-radius: var(--radius-lg); padding: 30px 26px; }
    @media (min-width: 760px){ .carto-panel { padding: 40px 44px; } }
    .carto-top { display: flex; align-items: center; gap: 18px; margin-bottom: 22px; }
    .carto-top .portrait { width: 64px; height: 64px; border-radius: 50%; object-fit: cover; flex-shrink: 0; border: 2px solid var(--hair-lime); }
    .carto-top h2 { font-family: 'Bricolage Grotesque', sans-serif; font-weight: 700; font-size: 26px; line-height: 1.08; letter-spacing: -0.02em; color: var(--text); }
    @media (min-width: 720px){ .carto-top h2 { font-size: 34px; } }
    .carto-top h2 .lime { color: var(--lime); }
    .carto-top .role { font-family: 'Space Mono', monospace; font-size: 10.5px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--faint); margin-top: 6px; }
    .carto-body { font-size: 15.5px; line-height: 1.7; color: var(--dim); max-width: 64ch; }
    .carto-body strong { color: var(--text); font-weight: 600; }
    .carto-body em { color: var(--teal); font-style: italic; }
    .carto-stats { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1px; margin: 26px 0 0; background: var(--hair); border: 1px solid var(--hair); border-radius: var(--radius); overflow: hidden; }
    @media (min-width: 640px){ .carto-stats { grid-template-columns: repeat(4, 1fr); } }
    .carto-stats > div { background: var(--bg-2); padding: 18px 16px; }
    .carto-stats .fig { font-family: 'Bricolage Grotesque', sans-serif; font-weight: 800; font-size: 26px; line-height: 1; color: var(--lime); letter-spacing: -0.02em; }
    .carto-stats .cap { font-size: 11.5px; color: var(--dim); margin-top: 7px; line-height: 1.4; }
    .carto-map { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 24px; }
    .carto-map .legend { font-family: 'Space Mono', monospace; font-size: 10px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--dim); padding: 7px 12px; border: 1px solid var(--hair); border-radius: var(--pill); display: inline-flex; align-items: center; gap: 8px; }
    .carto-map .legend b { color: var(--text); font-weight: 700; }
    .carto-map .legend .pin { width: 8px; height: 8px; border-radius: 50%; background: var(--teal); }
    .carto-avail { display: flex; align-items: flex-start; gap: 13px; margin-top: 22px; padding-top: 22px; border-top: 1px solid var(--hair); }
    .carto-avail svg { width: 24px; height: 24px; color: var(--lime); flex-shrink: 0; margin-top: 2px; }
    .carto-avail p { font-size: 14.5px; line-height: 1.6; color: var(--text); }
    .carto-avail p strong { color: var(--lime); font-weight: 600; }

    /* ============ CTA ============ */
    .cta { padding: 80px 0 24px; text-align: center; }
    .cta .dl { font-family: 'Space Mono', monospace; font-size: 11px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: var(--lime); }
