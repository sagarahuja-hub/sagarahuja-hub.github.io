      font-size: 22px;
      color: var(--fc-body);
      margin-bottom: 14px;
      letter-spacing: -0.01em;
    }
    .fc-pp .pp-about p {
      font-size: 14px;
      color: var(--fc-body);
      line-height: 1.7;
      margin-bottom: 12px;
    }
    .fc-pp .pp-about .pp-section-title {
      font-size: 14px;
      font-weight: 600;
      color: var(--fc-body);
      margin-top: 18px;
      margin-bottom: 8px;
