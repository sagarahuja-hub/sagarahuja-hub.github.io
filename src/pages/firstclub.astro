---
import PitchLayout from '../layouts/PitchLayout.astro';
---
<PitchLayout
  title="Sagar Ahuja – FirstClub Product Analysis"
  description="4 product problems FirstClub needs to solve in the next 12 months. Prepared by Sagar Ahuja, Senior Product Leader."
  slug="firstclub"
  fonts="Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@300;400;500;600;700"
>
  <style slot="head" is:global>
    :root {
      --fc-green: #1C4A1E;
      --fc-green-soft: #2A6B2D;
      --fc-green-light: #A8C5A0;
      --fc-bg: #F5F0E8;
      --fc-card-bg: #EDE8DE;
      --fc-border: #C8D9C6;
      --fc-body: #1C2B1A;
      --fc-secondary: #4A5A48;
      --fc-muted: #8A9A88;
      --fc-cream-text: #F5F0E8;
      --fc-cream-dim: #C8D9C6;
      --fc-highlight-bg: rgba(28, 74, 30, 0.06);
      --fc-radius: 4px;
      --fc-radius-lg: 8px;
      --fc-radius-pill: 999px;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    html { -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
      background: var(--fc-bg);
      color: var(--fc-body);
      font-size: 15px;
      line-height: 1.6;
      font-weight: 400;
    }
    .fc-page { max-width: 860px; margin: 0 auto; padding: 40px 24px 80px; }
    @media (min-width: 720px) { .fc-page { padding: 56px 32px 96px; } }

    /* Inline emphasis */
    strong.k {
      color: var(--fc-green);
      font-weight: 600;
      background: var(--fc-highlight-bg);
      padding: 1px 5px;
      border-radius: 3px;
      white-space: nowrap;
    }
    em.c { color: var(--fc-secondary); font-style: italic; font-weight: 500; }

    .fc-eyebrow {
      font-family: 'Inter', sans-serif;
      font-size: 11.5px;
      font-weight: 700;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--fc-green);
      display: inline-block;
    }

    /* ===== Section 1: Header ===== */
    .fc-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 24px;
      padding-bottom: 18px;
      border-bottom: 2px solid var(--fc-green);
      margin-bottom: 36px;
      flex-wrap: wrap;
    }
    .fc-header .name-block .name {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: 22px;
      font-weight: 600;
      color: var(--fc-green);
      letter-spacing: -0.01em;
      margin-bottom: 4px;
    }
    .fc-header .name-block .role {
      font-size: 10.5px;
      font-weight: 500;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--fc-secondary);
    }
    .fc-header .contact-block {
      text-align: right;
      font-size: 12px;
      color: var(--fc-secondary);
      line-height: 1.7;
    }
    .fc-header .contact-block a {
      color: var(--fc-secondary);
      text-decoration: none;
      transition: color 0.15s ease;
    }
    .fc-header .contact-block a:hover { color: var(--fc-green); }
    @media (max-width: 540px) { .fc-header .contact-block { text-align: left; } }

    /* ===== Today's Specials section (mirrors FirstClub app) ===== */
    .fc-specials {
      margin: 36px 0;
      padding: 32px 18px 36px;
      background: linear-gradient(180deg, #E8EFC5 0%, #F4ECC8 100%);
      border-radius: var(--fc-radius-lg);
      position: relative;
      overflow: hidden;
    }
    .fc-specials::before {
      content: 'SPECIALS';
      position: absolute;
      top: 14px;
      left: 0;
      right: 0;
      text-align: center;
      font-family: 'Playfair Display', Georgia, serif;
      font-size: 72px;
      font-weight: 700;
      color: rgba(28, 74, 30, 0.07);
      letter-spacing: 0.14em;
      text-transform: uppercase;
      z-index: 0;
      user-select: none;
      pointer-events: none;
      line-height: 1;
    }
    @media (min-width: 720px) { .fc-specials::before { font-size: 112px; top: 20px; } }
    @media (min-width: 720px) { .fc-specials { padding: 44px 24px 44px; } }

    .fc-specials .ts-head {
      text-align: center;
      position: relative;
      z-index: 1;
      margin-bottom: 22px;
    }
    .fc-specials .ts-head h2 {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: 30px;
      font-weight: 700;
      color: var(--fc-green);
      line-height: 1.1;
      margin-bottom: 6px;
      letter-spacing: -0.015em;
    }
    @media (min-width: 720px) { .fc-specials .ts-head h2 { font-size: 36px; } }
    .fc-specials .ts-head .sub {
      font-size: 14px;
      color: var(--fc-green-soft);
      font-weight: 400;
      font-family: 'Inter', sans-serif;
    }

    .fc-specials .ts-cards {
      display: grid;
      grid-template-columns: 1fr;
      gap: 12px;
      position: relative;
      z-index: 1;
    }
    @media (min-width: 540px) {
      .fc-specials .ts-cards { grid-template-columns: repeat(3, 1fr); gap: 12px; }
    }

    .fc-special-card {
      border-radius: var(--fc-radius-lg);
      padding: 14px 12px 16px;
      text-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 8px;
      position: relative;
      overflow: hidden;
    }
    .fc-special-card.sc-1 { background: linear-gradient(180deg, #FFE4B5 0%, #FFD78A 100%); }
    .fc-special-card.sc-2 { background: linear-gradient(180deg, #DCE8B8 0%, #C0DC9C 100%); }
    .fc-special-card.sc-3 { background: linear-gradient(180deg, #FFE0B0 0%, #FFC97D 100%); }

    .fc-special-card .sc-label {
      font-family: 'Inter', sans-serif;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      line-height: 1.25;
      padding: 0 6px;
      min-height: 28px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .fc-special-card.sc-1 .sc-label { color: #8A5A18; }
    .fc-special-card.sc-2 .sc-label { color: #3F6B22; }
    .fc-special-card.sc-3 .sc-label { color: #8A5A18; }

    .fc-special-card .sc-image {
      width: 100%;
      aspect-ratio: 4 / 3;
      border-radius: var(--fc-radius);
      overflow: hidden;
      background: rgba(255, 255, 255, 0.35);
    }
    .fc-special-card .sc-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    .fc-special-card .sc-caption {
      font-family: 'Inter', sans-serif;
      font-size: 13.5px;
      font-weight: 700;
      color: var(--fc-body);
      line-height: 1.3;
      padding: 4px 4px 0;
    }
    .fc-special-card .sc-meta {
      font-family: 'Inter', sans-serif;
      font-size: 11px;
      color: var(--fc-secondary);
      font-weight: 500;
    }

    /* ===== Product page mock card (mirrors FirstClub product page) ===== */
    .fc-pp {
      max-width: 520px;
      margin: 36px auto 24px;
      background: #fff;
      border: 1px solid var(--fc-border);
      border-radius: var(--fc-radius-lg);
      overflow: hidden;
      box-shadow: 0 4px 16px rgba(28, 74, 30, 0.08);
    }
    .fc-pp .pp-nav {
      display: flex;
      align-items: center;
      padding: 14px 16px;
      border-bottom: 1px solid var(--fc-border);
      font-size: 14px;
      gap: 12px;
    }
    .fc-pp .pp-nav .back {
      width: 30px;
      height: 30px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      color: var(--fc-body);
      font-size: 18px;
      cursor: default;
    }
    .fc-pp .pp-nav .title {
      flex: 1;
      font-weight: 700;
      color: var(--fc-body);
      font-size: 15px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .fc-pp .pp-nav .share {
      width: 34px;
      height: 34px;
      border-radius: 50%;
      background: #f3efe5;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      color: var(--fc-secondary);
      font-size: 13px;
    }

    .fc-pp .pp-hero {
      background: linear-gradient(180deg, #E8DCB0 0%, #DCC788 100%);
      padding: 28px 24px 36px;
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 320px;
    }
    .fc-pp .pp-hero img {
      width: 200px;
      height: 240px;
      border-radius: 10px;
      object-fit: cover;
      object-position: center 22%;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.18);
    }
    .fc-pp .pp-dots {
      position: absolute;
      bottom: 12px;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      gap: 4px;
      padding: 5px 9px;
      background: rgba(0, 0, 0, 0.18);
      border-radius: var(--fc-radius-pill);
    }
    .fc-pp .pp-dots span {
      width: 4px;
      height: 4px;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.55);
    }
    .fc-pp .pp-dots span.active {
      background: #fff;
      width: 16px;
      border-radius: 2px;
    }

    .fc-pp .pp-pills {
      display: flex;
      gap: 8px;
      padding: 14px 16px 8px;
      flex-wrap: wrap;
    }
    .fc-pp .pp-pill {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 5px 10px;
      border-radius: var(--fc-radius-pill);
      border: 1px solid var(--fc-border);
      font-size: 11.5px;
      color: var(--fc-body);
      font-weight: 500;
      background: #fff;
      white-space: nowrap;
    }
    .fc-pp .pp-pill.featured {
      background: rgba(168, 197, 160, 0.20);
      border-color: var(--fc-green-light);
      color: var(--fc-green);
    }
    .fc-pp .pp-pill .leaf {
      width: 9px;
      height: 9px;
      background: var(--fc-green);
      transform: rotate(45deg);
      border-radius: 2px;
    }

    .fc-pp .pp-brand {
      padding: 6px 16px 0;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.14em;
      color: var(--fc-muted);
      text-transform: uppercase;
    }
    .fc-pp .pp-title {
      padding: 4px 16px 0;
      font-family: 'Playfair Display', Georgia, serif;
      font-size: 24px;
      font-weight: 700;
      color: var(--fc-body);
      line-height: 1.18;
      letter-spacing: -0.015em;
    }
    .fc-pp .pp-weight {
      padding: 2px 16px 0;
      font-size: 14px;
      color: var(--fc-muted);
      font-weight: 400;
    }
    .fc-pp .pp-price {
      padding: 10px 16px 18px;
      display: flex;
      align-items: baseline;
      gap: 10px;
    }
    .fc-pp .pp-price-now {
      font-family: 'Inter', sans-serif;
      font-size: 22px;
      font-weight: 700;
      color: var(--fc-body);
    }
    .fc-pp .pp-price-was {
      font-size: 14px;
      color: var(--fc-muted);
      text-decoration: line-through;
    }

    .fc-pp .pp-about {
      padding: 22px 18px 8px;
      border-top: 1px solid var(--fc-border);
    }
    .fc-pp .pp-about h3 {
      font-family: 'Playfair Display', Georgia, serif;
      font-weight: 700;
      font-size: 22px;
      color: var(--fc-body);
      margin-bottom: 14px;
      letter-spacing: -0.01em;
    }
    .fc-pp .pp-about p {
      font-size: 14px;
      color: var(--fc-body);
      line-height: 1.7;
      margin-bottom: 12px;
    }
    .fc-pp .pp-about .pp-section-title {
      font-size: 14px;
      font-weight: 600;
      color: var(--fc-body);
      margin-top: 18px;
      margin-bottom: 6px;
    }
    .fc-pp .pp-about ul {
      list-style: none;
      padding-left: 0;
      margin-bottom: 8px;
    }
    .fc-pp .pp-about ul li {
      font-size: 14px;
      color: var(--fc-body);
      line-height: 1.7;
      padding: 1px 0;
    }
    .fc-pp .pp-about .pp-refund {
      margin-top: 18px;
      padding: 12px 14px;
      background: var(--fc-card-bg);
      border-left: 3px solid var(--fc-green);
      border-radius: var(--fc-radius);
      font-size: 13.5px;
      color: var(--fc-secondary);
      line-height: 1.6;
    }
    .fc-pp .pp-about .pp-refund strong { color: var(--fc-green); font-weight: 700; }

    .fc-pp .pp-cta-row {
      padding: 20px 18px 24px;
      background: #fff;
      border-top: 1px solid var(--fc-border);
    }
    .fc-pp .pp-cta {
      display: block;
      width: 100%;
      padding: 17px 24px;
      background: var(--fc-green);
      color: var(--fc-cream-text);
      text-align: center;
      font-family: 'Inter', sans-serif;
      font-size: 16px;
      font-weight: 600;
      border: none;
      border-radius: var(--fc-radius-pill);
      cursor: pointer;
      text-decoration: none;
      transition: background 0.18s ease, transform 0.18s ease, box-shadow 0.18s ease;
      letter-spacing: 0.005em;
      box-shadow: 0 4px 12px rgba(28, 74, 30, 0.25);
    }
    .fc-pp .pp-cta:hover {
      background: var(--fc-green-soft);
      transform: translateY(-1px);
      box-shadow: 0 6px 16px rgba(28, 74, 30, 0.32);
    }

    /* ===== Section header + framing pull-quote ===== */
    .fc-section-head { margin-top: 64px; margin-bottom: 12px; }
    .fc-section-head .eyebrow-row {
      display: flex;
      align-items: center;
      gap: 14px;
      margin-bottom: 8px;
    }
    .fc-section-head .eyebrow-row::after {
      content: '';
      flex: 1;
      height: 1px;
      background: linear-gradient(90deg, var(--fc-green) 0%, transparent 100%);
    }
    .fc-section-head h2 {
      font-family: 'Playfair Display', Georgia, serif;
      font-weight: 600;
      font-size: 28px;
      line-height: 1.2;
      color: var(--fc-green);
      letter-spacing: -0.01em;
      margin-bottom: 6px;
    }
    @media (min-width: 720px) { .fc-section-head h2 { font-size: 34px; } }

    .fc-framing {
      margin: 28px 0 36px;
      padding: 22px 26px;
      background: var(--fc-card-bg);
      border-left: 4px solid var(--fc-green);
      border-radius: var(--fc-radius);
    }
    .fc-framing .quote {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: 20px;
      font-style: italic;
      font-weight: 400;
      line-height: 1.45;
      color: var(--fc-green);
      margin-bottom: 8px;
      letter-spacing: -0.005em;
    }
    @media (min-width: 720px) { .fc-framing .quote { font-size: 23px; } }
    .fc-framing .quote::before {
      content: '"';
      font-family: 'Playfair Display', serif;
      font-size: 1.4em;
      line-height: 1;
      vertical-align: -0.05em;
      color: var(--fc-green-light);
      margin-right: 2px;
    }
    .fc-framing .quote::after {
      content: '"';
      font-family: 'Playfair Display', serif;
      font-size: 1.4em;
      line-height: 1;
      vertical-align: -0.05em;
      color: var(--fc-green-light);
    }
    .fc-framing .tail {
      font-size: 13.5px;
      color: var(--fc-secondary);
      font-weight: 500;
      letter-spacing: 0.01em;
    }

    /* ===== Problem cards ===== */
    .fc-problem {
      background: var(--fc-card-bg);
      border: 1px solid var(--fc-border);
      border-left: 4px solid var(--fc-green);
      border-radius: var(--fc-radius);
      padding: 28px 28px 28px 30px;
      margin-bottom: 24px;
      position: relative;
    }
    @media (min-width: 720px) { .fc-problem { padding: 34px 38px 34px 40px; } }

    .fc-problem .pr-num {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: 60px;
      font-weight: 400;
      color: var(--fc-green-light);
      line-height: 1;
      margin-bottom: 6px;
      letter-spacing: -0.02em;
    }
    @media (min-width: 720px) { .fc-problem .pr-num { font-size: 72px; } }

    .fc-problem .pr-title {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: 21px;
      font-weight: 600;
      color: var(--fc-green);
      line-height: 1.3;
      margin-bottom: 24px;
      letter-spacing: -0.01em;
    }
    @media (min-width: 720px) { .fc-problem .pr-title { font-size: 24px; } }

    .fc-problem .pr-block + .pr-block { margin-top: 24px; }
    .fc-problem .pr-label {
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--fc-green);
      margin-bottom: 12px;
      padding-top: 16px;
      border-top: 1px solid var(--fc-border);
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .fc-problem .pr-label::before {
      content: '';
      width: 18px;
      height: 2px;
      background: var(--fc-green);
      flex-shrink: 0;
    }
    .fc-problem .pr-block:first-of-type .pr-label { padding-top: 0; border-top: none; }
    .fc-problem .pr-block p {
      font-size: 14.5px;
      color: var(--fc-body);
      line-height: 1.75;
      margin-bottom: 12px;
    }
    .fc-problem .pr-block p:last-child { margin-bottom: 0; }

    .fc-problem .pr-block:first-of-type p:first-of-type::first-letter {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: 3.6em;
      float: left;
      line-height: 0.9;
      margin: 6px 10px 0 0;
      color: var(--fc-green);
      font-weight: 600;
    }

    .fc-problem .pr-sub {
      font-weight: 700;
      color: var(--fc-green);
      margin-top: 18px;
      margin-bottom: 6px;
      display: block;
      font-size: 14.5px;
      letter-spacing: -0.005em;
    }
    .fc-problem .pr-sub::before {
      content: '› ';
      color: var(--fc-green-light);
      font-weight: 400;
    }

    .fc-callout {
      margin: 14px 0;
      padding: 12px 16px;
      background: rgba(28, 74, 30, 0.05);
      border-left: 3px solid var(--fc-green-soft);
      border-radius: 0 var(--fc-radius) var(--fc-radius) 0;
      font-family: 'Playfair Display', Georgia, serif;
      font-style: italic;
      font-size: 15.5px;
      color: var(--fc-green);
      line-height: 1.5;
      letter-spacing: -0.005em;
    }

    /* ===== Why me ===== */
    .fc-why h3 {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: 18px;
      font-weight: 600;
      color: var(--fc-green);
      margin-top: 26px;
      margin-bottom: 10px;
      letter-spacing: -0.005em;
    }
    .fc-why p {
      font-size: 14.5px;
      color: var(--fc-body);
      line-height: 1.75;
      margin-bottom: 14px;
    }
    .fc-why .metric {
      font-style: italic;
      color: var(--fc-secondary);
      font-size: 14px;
      display: block;
      margin-top: 8px;
      padding: 8px 14px;
      border-left: 2px solid var(--fc-green-light);
      background: rgba(168, 197, 160, 0.10);
      border-radius: 0 var(--fc-radius) var(--fc-radius) 0;
    }
    .fc-why .metric strong { color: var(--fc-green); font-weight: 700; font-style: normal; }
    .fc-why .closing {
      margin-top: 28px;
      padding: 20px 24px;
      background: var(--fc-card-bg);
      border-left: 4px solid var(--fc-green);
      border-radius: var(--fc-radius);
      font-size: 15px;
      color: var(--fc-body);
      line-height: 1.65;
    }
    .fc-why .closing strong { color: var(--fc-green); font-weight: 700; }

    /* ===== CTA dark block ===== */
    .fc-dark-block {
      background: var(--fc-green);
      color: var(--fc-cream-text);
      padding: 28px;
      border-radius: var(--fc-radius-lg);
      margin: 36px 0;
      position: relative;
    }
    @media (min-width: 720px) { .fc-dark-block { padding: 36px 40px; } }
    .fc-dark-block h2 {
      font-family: 'Playfair Display', Georgia, serif;
      font-weight: 500;
      font-size: 22px;
      line-height: 1.35;
      color: var(--fc-cream-text);
      margin-bottom: 16px;
      letter-spacing: -0.005em;
    }
    @media (min-width: 720px) { .fc-dark-block h2 { font-size: 25px; } }
    .fc-dark-block p { color: var(--fc-cream-dim); font-size: 13.5px; line-height: 1.75; }
    .fc-dark-block p strong { color: var(--fc-cream-text); font-weight: 600; }
    .fc-cta-contact { margin-top: 22px; text-align: right; }
    .fc-cta-contact .label {
      font-size: 10.5px;
      font-weight: 700;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--fc-green-light);
      margin-bottom: 6px;
      display: block;
    }
    .fc-cta-contact a {
      color: var(--fc-cream-text);
      text-decoration: none;
      font-size: 14px;
      display: block;
      transition: opacity 0.15s ease;
    }
    .fc-cta-contact a:hover { opacity: 0.75; }
    @media (max-width: 540px) { .fc-cta-contact { text-align: left; } }

    /* ===== Footer ===== */
    .fc-footer {
      margin-top: 56px;
      padding-top: 24px;
      border-top: 1px solid var(--fc-border);
      text-align: center;
      font-size: 11.5px;
      color: var(--fc-muted);
