    /* ===== Mobile phone frame (<= 1179px) - pinned + scroll-jacked ===== */
    @media (max-width: 1179px) {
      /* Outer pinner determines how much page scroll maps to in-phone scroll */
      .fc-phone-pinner {
        position: relative;
      }

      .fc-phone {
        background: linear-gradient(160deg, #1a1a1a 0%, #2a2a2a 100%);
        border-radius: 42px;
        padding: 10px 8px 12px;
        box-shadow:
          0 18px 36px rgba(0, 0, 0, 0.18),
          0 8px 22px rgba(28, 74, 30, 0.12),
          inset 0 0 0 1.5px #3a3a3a,
          inset 0 1px 0 rgba(255, 255, 255, 0.05);
        position: sticky;
        top: 20px;
        max-width: 380px;
        margin: 24px auto;
      }
      /* Dynamic Island pill */
      .fc-phone::before {
        content: '';
        position: absolute;
        top: 18px;
        left: 50%;
        transform: translateX(-50%);
        width: 90px;
        height: 22px;
        background: #000;
        border-radius: 14px;
        z-index: 3;
      }
      /* Volume button */
      .fc-phone::after {
        content: '';
        position: absolute;
        left: -2px;
        top: 95px;
        width: 3px;
        height: 40px;
        background: #2a2a2a;
        border-radius: 2px 0 0 2px;
        box-shadow:
          0 50px 0 #2a2a2a,
          0 110px 0 0 #2a2a2a;
      }

      .fc-phone-screen {
        background: #fff;
        border-radius: 34px;
        overflow: hidden;
        position: relative;
        /* Dynamic viewport height so the phone grows as the iOS URL bar
           collapses during scroll; svh would lock the phone at the small
           viewport and leave a band of cream below it. vh stays as a
           fallback for browsers without dvh support. */
        height: min(640px, calc(100vh - 70px));
        height: min(640px, calc(100dvh - 70px));
      }
      /* Status-bar spacer so content does not collide with the island */
      .fc-phone-screen::before {
        content: '';
        display: block;
        height: 46px;
        background: #fff;
      }
      /* Inner wrapper that JS translates on scroll */
      .fc-phone-content {
        will-change: transform;
        transition: transform 0.05s linear;
      }
      @media (prefers-reduced-motion: reduce) {
        .fc-phone-content { transition: none; }
      }

      /* Reset showcase styling inside the phone */
      .fc-phone .fc-showcase {
        margin: 0;
        max-width: none;
        border: none;
        border-radius: 0;
        box-shadow: none;
      }

      /* Soft fade at the bottom hinting at more content */
      .fc-phone .fc-phone-fade {
        display: block;
        position: absolute;
        left: 8px;
        right: 8px;
        bottom: 12px;
        height: 60px;
        border-radius: 0 0 32px 32px;
        background: linear-gradient(180deg, rgba(255, 255, 255, 0) 0%, rgba(255, 255, 255, 0.92) 70%, #fff 100%);
        pointer-events: none;
        z-index: 4;
        transition: opacity 0.35s ease;
      }
      /* Scroll affordance pill */
      .fc-phone .fc-scroll-hint {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        position: absolute;
        bottom: 26px;
        left: 50%;
        transform: translateX(-50%);
        background: var(--fc-green);
        color: var(--fc-cream-text);
        padding: 7px 12px 7px 14px;
        border-radius: var(--fc-radius-pill);
        font-family: 'Inter', sans-serif;
        font-size: 9.5px;
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        z-index: 5;
        pointer-events: none;
        box-shadow: 0 6px 16px rgba(28, 74, 30, 0.32);
        animation: scrollHintBob 1.8s ease-in-out infinite;
        transition: opacity 0.35s ease;
      }
      .fc-phone .fc-scroll-hint svg { width: 11px; height: 11px; }
      .fc-phone.is-scrolled .fc-scroll-hint,
      .fc-phone.is-scrolled .fc-phone-fade { opacity: 0; }

      /* Vertical progress bar on the phone's right edge */
      .fc-phone .fc-phone-progress {
        display: block;
        position: absolute;
        right: 2px;
        top: 110px;
        bottom: 110px;
        width: 3px;
        border-radius: 2px;
        background: rgba(255, 255, 255, 0.08);
        z-index: 4;
        overflow: hidden;
        opacity: 0.85;
      }
      .fc-phone .fc-phone-progress::after {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: var(--fc-progress, 0%);
        background: linear-gradient(180deg, var(--fc-green-light) 0%, var(--fc-green) 100%);
        border-radius: 2px;
        transition: height 0.08s linear;
      }

      /* Tighten content inside the phone (same scale as desktop overrides) */
      .fc-phone .fc-specials { padding: 22px 12px 22px; }
      .fc-phone .fc-specials::before { font-size: 52px; top: 8px; }
      .fc-phone .fc-specials .ts-head { margin-bottom: 14px; }
      .fc-phone .fc-specials .ts-head h2 { font-size: 22px; }
      .fc-phone .fc-specials .ts-head .sub { font-size: 11px; }
      .fc-phone .fc-specials .ts-cards { gap: 6px; }
      .fc-phone .fc-special-card { padding: 8px 6px 10px; gap: 5px; }
      .fc-phone .fc-special-card .sc-image { width: 48px; height: 48px; }
      .fc-phone .fc-special-card .sc-label { font-size: 9px; min-height: 22px; }
      .fc-phone .fc-special-card .sc-caption { font-size: 10.5px; }
      .fc-phone .fc-special-card .sc-meta { font-size: 9.5px; }

      .fc-phone .fc-pp .pp-nav { padding: 6px 12px; }
      .fc-phone .fc-pp .pp-nav .title { font-size: 13px; }
      .fc-phone .fc-pp .pp-nav .back { width: 22px; height: 22px; font-size: 15px; }
      .fc-phone .fc-pp .pp-nav .share { width: 26px; height: 26px; font-size: 11px; }

      .fc-phone .fc-pp .pp-hero .pp-badge { font-size: 9.5px; padding: 4px 10px 4px 8px; }
      .fc-phone .fc-pp .pp-hero .pp-badge svg { width: 10px; height: 10px; }

      .fc-phone .fc-pp .pp-gallery { padding: 18px 9% 28px; gap: 10px; }
