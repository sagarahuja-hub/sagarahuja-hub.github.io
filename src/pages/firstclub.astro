        <a href="mailto:sagarahuja@gmail.com">sagarahuja@gmail.com</a>
        <a href="tel:+919557629225">+91 9557 629 225</a>
        <a href="https://sagarahuja.co" target="_blank" rel="noopener">sagarahuja.co</a>
        <a href="https://linkedin.com/in/sagar-ahuja-/" target="_blank" rel="noopener">linkedin.com/in/sagar-ahuja-</a>
      </div>
    </section>

    <footer class="fc-footer">
      Prepared for exclusive partnership with FirstClub · June 2026 · Not indexed - shared by direct link only
    </footer>

  </div>

  <script slot="head" is:inline>
    document.addEventListener('DOMContentLoaded', function() {
      if ('IntersectionObserver' in window) {
        var io = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              io.unobserve(entry.target);
            }
          });
        }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
        document.querySelectorAll('.reveal, .reveal-stagger').forEach(function(el) { io.observe(el); });
      } else {
        document.querySelectorAll('.reveal, .reveal-stagger').forEach(function(el) { el.classList.add('visible'); });
      }

      var gallery = document.getElementById('pp-gallery');
      var dotsWrap = document.getElementById('pp-dots');
      var prevBtn = document.getElementById('pp-prev');
      var nextBtn = document.getElementById('pp-next');
      if (!gallery || !dotsWrap) return;
      var dots = dotsWrap.querySelectorAll('span');
      var slides = gallery.querySelectorAll('.pp-slide');
      var total = slides.length;
      var current = 0;

      function getSlideStep() {
        if (slides.length < 2) return gallery.clientWidth;
        return slides[1].offsetLeft - slides[0].offsetLeft;
      }

      var badgeText = document.getElementById('pp-badge-text');
      function updateUI(i) {
        current = i;
        dots.forEach(function(d, idx) { d.classList.toggle('active', idx === i); });
        if (prevBtn) prevBtn.disabled = i <= 0;
        if (nextBtn) nextBtn.disabled = i >= total - 1;
        if (badgeText && slides[i]) {
          var tag = slides[i].getAttribute('data-tag');
          if (tag) badgeText.textContent = tag;
        }
      }

      function scrollTo(i) {
        var step = getSlideStep();
        var target = i * step;
        gallery.scrollTo({ left: target, behavior: 'smooth' });
        updateUI(i);
      }

      gallery.addEventListener('scroll', function() {
        var step = getSlideStep();
        if (step <= 0) return;
        var idx = Math.round(gallery.scrollLeft / step);
        if (idx >= 0 && idx < total && idx !== current) updateUI(idx);
      }, { passive: true });

      dots.forEach(function(d, i) {
        d.addEventListener('click', function() { scrollTo(i); });
      });
      if (prevBtn) prevBtn.addEventListener('click', function() { if (current > 0) scrollTo(current - 1); });
      if (nextBtn) nextBtn.addEventListener('click', function() { if (current < total - 1) scrollTo(current + 1); });
      updateUI(0);

      var phone = document.querySelector('.fc-phone');
      var phoneScreen = document.querySelector('.fc-phone-screen');
      var phoneContent = document.querySelector('.fc-phone-content');
      var phonePinner = document.querySelector('.fc-phone-pinner');
      var phoneProgress = document.querySelector('.fc-phone-progress');

      var MOBILE_BREAKPOINT = 1180;
      function isMobileViewport() { return window.innerWidth < MOBILE_BREAKPOINT; }

      // Desktop: inner scrollTop drives the .is-scrolled fade + CTA reach
      if (phone && phoneScreen) {
        phoneScreen.addEventListener('scroll', function() {
          if (isMobileViewport()) return;
          var max = phoneScreen.scrollHeight - phoneScreen.clientHeight;
          var ratio = max > 0 ? Math.min(1, phoneScreen.scrollTop / max) : 0;
          if (phoneScreen.scrollTop > 30) phone.classList.add('is-scrolled');
          else phone.classList.remove('is-scrolled');
          if (ratio >= 0.94) phone.classList.add('is-cta-reached');
          else phone.classList.remove('is-cta-reached');
          if (phoneProgress) phoneProgress.style.setProperty('--fc-progress', (ratio * 100).toFixed(1) + '%');
        }, { passive: true });
      }

      // On mobile, .fc-phone-screen is overflow:hidden, so reveals nested
      // inside it can be missed by IntersectionObserver. Force them visible
      // upfront so they are not stuck at opacity 0 forever.
      if (phone && isMobileViewport()) {
        phone.querySelectorAll('.reveal, .reveal-stagger').forEach(function(el) {
          el.classList.add('visible');
        });
      }

      // Mobile: scroll-jack. The phone is position:sticky inside a tall
      // .fc-phone-pinner; as the page scrolls, we translate .fc-phone-content
      // upward, then release when content is exhausted.
      if (phone && phoneScreen && phoneContent && phonePinner) {
        // Pacing knobs. The Lab Report and the Add to FirstClub CTA sit at
        // the very bottom of the content; the user complained both were
        // 'buried' in the scroll. We slow the last part of the reveal with
        // an ease-out curve and then hold the phone at progress = 1 for a
        // short dwell so the CTA gets time to land.
        var SLOW_FACTOR = 1.15;     // 15% more page scroll than raw content
        var END_DWELL_PX = 170;     // page-px held at progress = 1 before unstick
        var CTA_THRESHOLD = 0.94;   // progress at which we flag is-cta-reached

        var overflow = 0;
        var contentScrollPx = 0;
        var stickyOffset = 20;
        var ticking = false;

        // Ease-out quad: fast at start, slow at end. Spends more page scroll
        // on the last slice of content (the Lab Report and CTA).
        function easeOutQuad(t) { return 1 - (1 - t) * (1 - t); }

        function recompute() {
          if (!isMobileViewport()) {
            phoneContent.style.transform = '';
            phonePinner.style.height = '';
            phone.classList.remove('is-scrolled');
            phone.classList.remove('is-cta-reached');
            if (phoneProgress) phoneProgress.style.setProperty('--fc-progress', '0%');
            return;
          }
          // Measure without any active transform. Use the phone-screen's own
          // scrollHeight so the ::before status-bar spacer is included; if we
          // measured phoneContent alone the translation would fall short by
          // the spacer's height and the Add to FirstClub CTA would be hidden.
          phoneContent.style.transform = '';
          var scrollH = phoneScreen.scrollHeight;
          var clientH = phoneScreen.clientHeight;
          // Small safety pad so trailing margins are not clipped on some UAs.
          overflow = Math.max(0, scrollH - clientH + 8);
          if (overflow === 0) {
            phonePinner.style.height = '';
            return;
          }
          var phoneH = phone.offsetHeight;
          contentScrollPx = overflow * SLOW_FACTOR;
          phonePinner.style.height = (phoneH + contentScrollPx + END_DWELL_PX) + 'px';
          applyScroll();
        }

        function applyScroll() {
          if (!isMobileViewport() || overflow === 0) return;
          var rect = phonePinner.getBoundingClientRect();
          var scrolled = stickyOffset - rect.top; // 0 when phone just stuck

          // Linear page-scroll position inside the reveal range, then dwell.
          var t;
          if (scrolled <= 0) t = 0;
          else if (scrolled >= contentScrollPx) t = 1;
          else t = scrolled / contentScrollPx;

          // Easing converts that linear page-position into actual content
          // progress. The last 20% of content takes ~35% of the scroll.
          var progress = easeOutQuad(t);
          var ty = -progress * overflow;
          phoneContent.style.transform = 'translate3d(0,' + ty.toFixed(1) + 'px,0)';

          if (progress > 0.04) phone.classList.add('is-scrolled');
          else phone.classList.remove('is-scrolled');

          // Once we are essentially showing the CTA, latch a class so CSS
          // can give the button a brighter shadow + faster pulse. The class
          // also persists through the dwell zone (t === 1).
          if (progress >= CTA_THRESHOLD) phone.classList.add('is-cta-reached');
          else phone.classList.remove('is-cta-reached');

          if (phoneProgress) phoneProgress.style.setProperty('--fc-progress', (progress * 100).toFixed(1) + '%');
        }

        window.addEventListener('scroll', function() {
          if (!ticking) {
            window.requestAnimationFrame(function() { applyScroll(); ticking = false; });
            ticking = true;
          }
        }, { passive: true });

        var resizeTimer;
        window.addEventListener('resize', function() {
          clearTimeout(resizeTimer);
          resizeTimer = setTimeout(recompute, 150);
        });

        window.addEventListener('load', recompute);

        // Recompute when in-phone content reflows (lazy-loaded gallery images,
        // font swap, etc). Without this the very first measurement can be
        // short, leaving the CTA at the bottom unreachable.
        if ('ResizeObserver' in window) {
          var ro = new ResizeObserver(function() {
            clearTimeout(resizeTimer);
            resizeTimer = setTimeout(recompute, 120);
          });
          ro.observe(phoneContent);
        }

        // Initial run (some content already laid out)
        recompute();
      }

      // ============ PostHog custom events ============
      // Fire only when posthog has finished loading (it is initialised in
      // PitchLayout's head). All helpers are no-ops if posthog is missing.
      function ph(event, props) {
        if (window.posthog && typeof window.posthog.capture === 'function') {
          window.posthog.capture(event, props || {});
        }
      }

      // 1. Resume download click
      var resumeLink = document.querySelector('.pp-lab-download');
      if (resumeLink) {
        resumeLink.addEventListener('click', function() {
          ph('resume_downloaded', {
            source: 'firstclub_lab_report',
            label: 'Download Full Report · Resume',
          });
        }, { passive: true });
      }

      // 2. Add to FirstClub CTA click
      var ctaLink = document.querySelector('.fc-pp .pp-cta');
      if (ctaLink) {
        ctaLink.addEventListener('click', function() {
          ph('cta_add_to_firstclub_clicked', {
            source: 'firstclub_product_card',
            href: ctaLink.getAttribute('href') || '',
          });
        }, { passive: true });
      }

      // 3. Phone scroll completion (fires once per page load, on either
      // mobile scroll-jack progress or desktop inner-scroll ratio reaching
      // the CTA-reached threshold).
      var phoneScrollFired = false;
      window.markPhoneScrollCompleted = function() {
        if (phoneScrollFired) return;
        phoneScrollFired = true;
        ph('phone_scroll_completed', {
          viewport_mode: window.innerWidth >= 1180 ? 'desktop' : 'mobile',
        });
      };
      // Watch the is-cta-reached class (added by both scroll paths). The
      // existing scroll handlers toggle this class; we observe it instead
      // of re-implementing the threshold logic in two places.
      if (phone && 'MutationObserver' in window) {
        var ctaObserver = new MutationObserver(function() {
          if (phone.classList.contains('is-cta-reached')) {
            window.markPhoneScrollCompleted();
          }
        });
        ctaObserver.observe(phone, { attributes: true, attributeFilter: ['class'] });
      }

      // Contact link tracking lives in PitchLayout.astro now (delegated for
      // all pitch pages, not just /firstclub).

      // 4. Per-problem-card view tracking. Fires once when each of the four
      // 12-month thesis cards scrolls into view.
      if ('IntersectionObserver' in window) {
        var problemFired = {};
        var problemIo = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (!entry.isIntersecting) return;
            var card = entry.target;
            var key = (card.querySelector('.pr-num') || {}).textContent || '';
            key = key.trim();
            if (!key || problemFired[key]) return;
            problemFired[key] = true;
            var title = ((card.querySelector('.pr-title') || {}).textContent || '').trim();
            ph('phone_problem_viewed', {
              problem_num: key,
              title: title,
            });
            problemIo.unobserve(card);
          });
        }, { threshold: 0.4 });
        document.querySelectorAll('.fc-problem').forEach(function(c) { problemIo.observe(c); });

        // 5. Per-why-me card view tracking
        var whyFired = {};
        var whyIo = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (!entry.isIntersecting) return;
            var card = entry.target;
            var area = ((card.querySelector('.why-area') || {}).textContent || '').trim();
            var link = ((card.querySelector('.why-link') || {}).textContent || '').trim();
            if (!area || whyFired[area]) return;
            whyFired[area] = true;
            ph('phone_why_me_viewed', {
              area: area,
              mapped_to: link,
            });
            whyIo.unobserve(card);
          });
        }, { threshold: 0.4 });
        document.querySelectorAll('.fc-why-card').forEach(function(c) { whyIo.observe(c); });
      }

      // 6. Hero gallery interactions. Hooks into the existing scrollTo() and
      // the prev/next/dot click handlers. We re-bind on top of them so the
      // existing logic still runs first.
      var galleryEl = document.getElementById('pp-gallery');
      var prevBtnEl = document.getElementById('pp-prev');
      var nextBtnEl = document.getElementById('pp-next');
      var dotsWrapEl = document.getElementById('pp-dots');
      if (galleryEl) {
        var slidesEl = galleryEl.querySelectorAll('.pp-slide');
        function slideTagAt(idx) {
          var s = slidesEl[idx];
          return s ? (s.getAttribute('data-tag') || '') : '';
        }
        function currentSlideIndex() {
          var step = slidesEl.length >= 2 ? (slidesEl[1].offsetLeft - slidesEl[0].offsetLeft) : galleryEl.clientWidth;
          if (step <= 0) return 0;
          return Math.round(galleryEl.scrollLeft / step);
        }
        if (prevBtnEl) {
          prevBtnEl.addEventListener('click', function() {
            // Fire after the existing handler has updated current
            setTimeout(function() {
              var i = currentSlideIndex();
              ph('phone_gallery_interaction', { type: 'prev', slide_index: i, slide_tag: slideTagAt(i) });
            }, 0);
          }, { passive: true });
        }
        if (nextBtnEl) {
          nextBtnEl.addEventListener('click', function() {
            setTimeout(function() {
              var i = currentSlideIndex();
              ph('phone_gallery_interaction', { type: 'next', slide_index: i, slide_tag: slideTagAt(i) });
            }, 0);
          }, { passive: true });
        }
        if (dotsWrapEl) {
          dotsWrapEl.querySelectorAll('span').forEach(function(dot, i) {
            dot.addEventListener('click', function() {
              ph('phone_gallery_interaction', { type: 'dot', slide_index: i, slide_tag: slideTagAt(i) });
            }, { passive: true });
          });
        }
        // Touch-swipe detection: fire once per touch sequence on the gallery
        var touchStartX = null;
        galleryEl.addEventListener('touchstart', function(ev) {
          touchStartX = ev.touches && ev.touches[0] ? ev.touches[0].clientX : null;
        }, { passive: true });
        galleryEl.addEventListener('touchend', function(ev) {
          if (touchStartX === null) return;
          var endX = ev.changedTouches && ev.changedTouches[0] ? ev.changedTouches[0].clientX : null;
          touchStartX = null;
          if (endX === null) return;
          // Fire after the snap settles
          setTimeout(function() {
            var i = currentSlideIndex();
            ph('phone_gallery_interaction', { type: 'swipe', slide_index: i, slide_tag: slideTagAt(i) });
          }, 200);
        }, { passive: true });
      }
    });
  </script>
</PitchLayout>
