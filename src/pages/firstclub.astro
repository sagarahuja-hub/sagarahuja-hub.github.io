      .fc-phone .fc-pp .pp-pills { padding: 12px 14px 6px; gap: 6px; }
      .fc-phone .fc-pp .pp-pill { font-size: 10.5px; padding: 4px 9px; }
      .fc-phone .fc-pp .pp-brand { padding: 6px 14px 0; font-size: 10px; }
      .fc-phone .fc-pp .pp-title { padding: 3px 14px 0; font-size: 20px; }
      .fc-phone .fc-pp .pp-weight { padding: 2px 14px 0; font-size: 13px; }
      .fc-phone .fc-pp .pp-price { padding: 8px 14px 16px; }
      .fc-phone .fc-pp .pp-price-now { font-size: 19px; }
      .fc-phone .fc-pp .pp-price-was { font-size: 13px; }

      .fc-phone .fc-pp .pp-about { padding: 18px 16px 6px; }
      .fc-phone .fc-pp .pp-about h3 { font-size: 19px; margin-bottom: 12px; }
      .fc-phone .fc-pp .pp-about p,
      .fc-phone .fc-pp .pp-about ul li { font-size: 13px; }
