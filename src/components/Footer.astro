---
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="inner">
    <div class="copy">
      <img src="/logo.png" alt="" class="footer-logo" aria-hidden="true" width="24" height="19" loading="lazy" />
      <span>&copy; {year} Sagar Ahuja</span>
    </div>
    <div class="links">
      <a href="https://linkedin.com/in/sagar-ahuja-/" target="_blank" rel="noopener">LinkedIn</a>
      <a href="mailto:sagarahuja@gmail.com">Email</a>
      <a href="/contact">Contact</a>
    </div>
  </div>
</footer>

<style>
  .site-footer .copy {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    color: var(--text-muted);
  }
  .site-footer .footer-logo {
    height: 19px;
    width: auto;
    display: block;
    opacity: 0.85;
    flex-shrink: 0;
  }
</style>
