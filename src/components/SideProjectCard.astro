---
import CardVisual from './CardVisual.astro';

interface Props {
  slug: string;
  title: string;
  type: string;
  year: string;
  summary: string;
  tags?: string[];
  link?: string;
  linkLabel?: string;
  mainHref?: string;
  icon?: string;
  status?: string;
  image?: string;
}

const {
  slug,
  title,
  type,
  year,
  summary,
  tags = [],
  link,
  linkLabel = 'Open',
  mainHref,
  icon,
  status = 'Completed',
  image
} = Astro.props;

// The card's primary click target. Defaults to the auto-generated detail
// page; entries can override (e.g. firstclub-pitch points straight at /firstclub).
const cardHref = mainHref ?? `/side-projects/${slug}`;
const readMoreLabel = mainHref ? 'Open project →' : 'Read more →';
---
<article class="side-card">
  <CardVisual icon={icon} status={status} image={image} alt={title} />
  <span class="corner tl" aria-hidden="true"></span>
  <span class="corner tr" aria-hidden="true"></span>
  <span class="corner bl" aria-hidden="true"></span>
  <span class="corner br" aria-hidden="true"></span>

  <div class="card-body">
    <div class="top-row" style="display:flex;justify-content:space-between;font-family:var(--font-mono);font-size:0.76rem;color:var(--text-dim);">
      <span>{type}</span>
      <span>{year}</span>
    </div>
    <h3>{title}</h3>
    <p class="summary" style="color:var(--text-muted);font-size:0.95rem;flex:1;">{summary}</p>
    {tags.length > 0 && (
      <div class="tags">
        {tags.map((t: string) => <span class="tag">{t}</span>)}
      </div>
    )}
    <div style="display:flex;gap:1rem;align-items:center;flex-wrap:wrap;margin-top:auto;">
      {/* The stretched anchor projects a click-area over the whole card via
          its ::after pseudo-element. Inner explicit links override it via
          z-index so the secondary CTA still works. */}
      <a href={cardHref} class="external stretched">{readMoreLabel}</a>
      {link && (
        <a href={link} target="_blank" rel="noopener" class="external on-top">{linkLabel} ↗</a>
      )}
    </div>
  </div>
</article>

<style>
  .side-card { position: relative; }
  /* Stretched link: the actual <a> still sits in its normal flow position,
     but its ::after expands to fill the whole .side-card, making any click
     on the card navigate there. */
  .side-card .external.stretched::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    border-radius: inherit;
  }
  /* The card itself gets a pointer cursor anywhere via the stretched layer.
     The secondary CTA + tags sit above the stretched area so their own
     hover state and click target win. */
  .side-card .external.on-top,
  .side-card .tag {
    position: relative;
    z-index: 2;
  }
</style>
