---
// Career time allocation (approximate, last 7 years in product)
const segments = [
  { label: 'Growth and Engagement', pct: 35, color: '#4f46e5' },
  { label: 'Platform and Experimentation', pct: 25, color: '#06b6d4' },
  { label: 'Lifecycle and Monetization', pct: 25, color: '#10b981' },
  { label: 'AI and Automation', pct: 15, color: '#f59e0b' }
];

const radius = 40;
const stroke = 14;
const circumference = 2 * Math.PI * radius;
let cumulative = 0;

const arcs = segments.map(s => {
  const length = (s.pct / 100) * circumference;
  const dasharray = `${length} ${circumference - length}`;
  const dashoffset = -cumulative;
  cumulative += length;
  return { ...s, dasharray, dashoffset };
});
---
<div class="about-focus">
  <div class="donut-wrap" style="position:relative;">
    <svg viewBox="0 0 100 100" class="donut" aria-hidden="true">
      <circle class="ring-bg" cx="50" cy="50" r={radius} />
      {arcs.map(a => (
        <circle
          class="seg"
          cx="50"
          cy="50"
          r={radius}
          stroke={a.color}
          stroke-dasharray={a.dasharray}
          stroke-dashoffset={a.dashoffset}
        ></circle>
      ))}
    </svg>
    <div class="donut-center" style="transform: none;">
      <span class="pct">7 yrs</span>
      <span class="main">Product</span>
    </div>
  </div>

  <div>
    <h4>Career focus (last 7 years)</h4>
    <div class="focus-legend">
      {segments.map(s => (
        <div class="item">
          <span class="swatch" style={`background:${s.color}`}></span>
          <span class="name">{s.label}</span>
          <span class="pct">~{s.pct}%</span>
        </div>
      ))}
    </div>
    <p class="focus-caption">Approximate allocation across product charters - growth, platform work, lifecycle, and the recent shift toward AI-native systems.</p>
  </div>
</div>
