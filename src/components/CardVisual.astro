---
import Icon from './Icon.astro';

interface Props {
  icon?: string;
  status?: string;
}

const { icon = 'target', status = 'Completed' } = Astro.props;

const ICON_GRADIENTS: Record<string, { from: string; to: string }> = {
  sparkles: { from: '#8b5cf6', to: '#ec4899' },
  cpu: { from: '#4f46e5', to: '#06b6d4' },
  'file-text': { from: '#0891b2', to: '#7c3aed' },
  activity: { from: '#10b981', to: '#0891b2' },
  smartphone: { from: '#3b82f6', to: '#06b6d4' },
  lightbulb: { from: '#f59e0b', to: '#fb923c' },
  send: { from: '#06b6d4', to: '#3b82f6' },
  target: { from: '#ef4444', to: '#f59e0b' },
  flask: { from: '#7c3aed', to: '#3b82f6' },
  shield: { from: '#10b981', to: '#059669' },
  'check-circle': { from: '#10b981', to: '#3b82f6' },
  award: { from: '#f59e0b', to: '#ef4444' },
  'trending-up': { from: '#10b981', to: '#06b6d4' },
  wrench: { from: '#64748b', to: '#4f46e5' },
  map: { from: '#3b82f6', to: '#7c3aed' },
  tv: { from: '#7c3aed', to: '#ec4899' },
  bell: { from: '#f59e0b', to: '#ec4899' }
};

const palette = ICON_GRADIENTS[icon] ?? ICON_GRADIENTS.target;
const bg = `linear-gradient(135deg, ${palette.from} 0%, ${palette.to} 100%)`;
const statusKey = status.toLowerCase();
---
<div class="card-visual">
  <div class="gen" style={`background: ${bg};`}>
    <svg viewBox="0 0 240 135" preserveAspectRatio="xMidYMid slice" style="position:absolute;inset:0;width:100%;height:100%;opacity:0.18;mix-blend-mode:soft-light;pointer-events:none;" aria-hidden="true">
      <defs>
        <pattern id={`dots-${icon}`} x="0" y="0" width="14" height="14" patternUnits="userSpaceOnUse">
          <circle cx="2" cy="2" r="1" fill="#fff"></circle>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill={`url(#dots-${icon})`}></rect>
    </svg>
    <Icon name={icon} size={64} class="icon-lg" />
  </div>
  <span class="status" data-status={statusKey}>{status}</span>
</div>
